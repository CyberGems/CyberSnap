<Window x:Class="CyberSnap.UI.TrayContextMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Width="290"
        SizeToContent="Height"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ShowActivated="True"
        Loaded="Window_Loaded"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <!-- Grid button style -->
        <Style x:Key="GridButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,12"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Height" Value="88"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Bottom general button style -->
        <Style x:Key="BottomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Exit button style -->
        <Style x:Key="BottomDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BottomButtonStyle}">
            <Setter Property="Foreground" Value="#EF4444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#15EF4444"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#EF4444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#25EF4444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource ThemeWindowBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Background="{DynamicResource ThemeInputBackgroundBrush}"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="-90" RenderingBias="Quality" ShadowDepth="3" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Grid Grid.Row="0" Margin="4,2,4,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TitleTextBlock"
                           Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                <Button Grid.Column="1"
                        Width="24"
                        Height="24"
                        Background="Transparent"
                        BorderBrush="Transparent"
                        Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                        Cursor="Hand"
                        Click="CloseButton_Click"
                        Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="Transparent"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Path Data="M 3,3 L 13,13 M 13,3 L 3,13"
                          Stroke="{DynamicResource ThemeTextSecondaryBrush}"
                          StrokeThickness="1.5"
                          Width="10"
                          Height="10"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Button>
            </Grid>

            <!-- Grid Tools -->
            <UniformGrid Grid.Row="1" Columns="2">
                <!-- Area Capture -->
                <Button x:Name="AreaCaptureBtn" Style="{StaticResource GridButtonStyle}" Click="AreaCapture_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="AreaCaptureIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="AreaCaptureText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Scroll Capture -->
                <Button x:Name="ScrollCaptureBtn" Style="{StaticResource GridButtonStyle}" Click="ScrollCapture_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="ScrollCaptureIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="ScrollCaptureText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- OCR -->
                <Button x:Name="OcrBtn" Style="{StaticResource GridButtonStyle}" Click="Ocr_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="OcrIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="OcrText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- QR & Barcodes -->
                <Button x:Name="QrBtn" Style="{StaticResource GridButtonStyle}" Click="QrScan_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="QrIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="QrText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Color Picker -->
                <Button x:Name="ColorPickerBtn" Style="{StaticResource GridButtonStyle}" Click="ColorPicker_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="ColorPickerIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="ColorPickerText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Ruler -->
                <Button x:Name="RulerBtn" Style="{StaticResource GridButtonStyle}" Click="Ruler_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="RulerIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="RulerText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Screen Recorder (MP4) -->
                <Button x:Name="VideoRecordBtn" Style="{StaticResource GridButtonStyle}" Click="VideoRecord_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="VideoRecordIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="VideoRecordText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Screen Recorder (GIF) -->
                <Button x:Name="GifRecordBtn" Style="{StaticResource GridButtonStyle}" Click="GifRecord_Click">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="GifRecordIcon" Width="32" Height="32" Margin="0,0,0,8" HorizontalAlignment="Center" Stretch="Uniform"/>
                        <TextBlock x:Name="GifRecordText" FontSize="12.5" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- Separator -->
            <Border Grid.Row="2" Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="4,6,4,6"/>

            <!-- Bottom Actions -->
            <StackPanel Grid.Row="3">
                <!-- Editor & Gallery in the same row -->
                <UniformGrid Columns="2">
                    <!-- Editor (left) -->
                    <Button x:Name="AnnotationsBtn"
                            Style="{StaticResource BottomButtonStyle}"
                            Click="Annotations_Click"
                            Padding="8,10"
                            Margin="4,2,2,2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="AnnotationsIcon" Width="16" Height="16" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AnnotationsText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="86"/>
                        </StackPanel>
                    </Button>

                    <!-- Gallery (right) -->
                    <Button x:Name="GalleryBtn"
                            Style="{StaticResource BottomButtonStyle}"
                            Click="Gallery_Click"
                            Padding="8,10"
                            Margin="2,2,4,2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="GalleryIcon" Width="16" Height="16" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="GalleryText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="86"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

                <!-- Exit & Settings in the same row (compact: short labels + full tooltips) -->
                <UniformGrid Columns="2">
                    <!-- Exit (left) -->
                    <Button x:Name="ExitBtn"
                            Style="{StaticResource BottomDangerButtonStyle}"
                            Click="Exit_Click"
                            Padding="8,10"
                            Margin="4,2,2,2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="ExitIcon" Width="16" Height="16" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ExitText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="86"/>
                        </StackPanel>
                    </Button>

                    <!-- Settings (right) -->
                    <Button x:Name="SettingsBtn"
                            Style="{StaticResource BottomButtonStyle}"
                            Click="Settings_Click"
                            Padding="8,10"
                            Margin="2,2,4,2">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Image x:Name="SettingsIcon" Width="16" Height="16" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SettingsText"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="86"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </Border>
</Window>
