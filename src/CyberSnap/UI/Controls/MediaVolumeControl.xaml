<UserControl x:Class="CyberSnap.UI.Controls.MediaVolumeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             Height="40"
             MinWidth="150">

    <UserControl.Resources>
        <SolidColorBrush x:Key="VolumeTrackFillBrush" Color="#FF00E5CC"/>
        <SolidColorBrush x:Key="VolumeTrackBgBrush" Color="#3300E5CC"/>
        <SolidColorBrush x:Key="VolumeTrackMutedFillBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="VolumeTrackMutedBgBrush" Color="#18FFFFFF"/>

        <Style x:Key="VolumeTrackDecreaseButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border x:Name="Fill"
                                Height="6"
                                CornerRadius="3,0,0,3"
                                Background="{DynamicResource VolumeTrackFillBrush}"
                                SnapsToDevicePixels="True"/>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsExportMuted, ElementName=Root}" Value="True">
                                <Setter TargetName="Fill" Property="Background" Value="{DynamicResource VolumeTrackMutedFillBrush}"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeTrackIncreaseButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VolumeSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Margin="6,0,8,0" Height="16">
                            <Border x:Name="TrackBackground"
                                    Height="6"
                                    CornerRadius="3"
                                    Background="{DynamicResource VolumeTrackBgBrush}"
                                    VerticalAlignment="Center"
                                    SnapsToDevicePixels="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExportMuted, ElementName=Root}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource VolumeTrackMutedBgBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Null}"
                                                  Style="{StaticResource VolumeTrackDecreaseButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Null}"
                                                  Style="{StaticResource VolumeTrackIncreaseButton}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12"
                                           Height="12"
                                           FocusVisualStyle="{x:Null}"
                                           VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ThumbCircle"
                                                         Fill="{DynamicResource ThemeTextPrimaryBrush}"
                                                         Stroke="{DynamicResource VolumeTrackFillBrush}"
                                                         StrokeThickness="1.5"/>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding IsExportMuted, ElementName=Root}" Value="True">
                                                        <Setter TargetName="ThumbCircle" Property="Stroke" Value="{DynamicResource VolumeTrackMutedFillBrush}"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border x:Name="PillBorder"
            CornerRadius="20"
            Background="{DynamicResource ThemeInputBackgroundBrush}"
            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
            BorderThickness="1"
            Padding="4,0,8,0"
            ClipToBounds="False">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#22FFFFFF"/>
                    </Trigger>
                    <DataTrigger Binding="{Binding IsExportMuted, ElementName=Root}" Value="True">
                        <Setter Property="Opacity" Value="0.72"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <DockPanel LastChildFill="True" ClipToBounds="False">
            <Button x:Name="MuteBtn"
                    DockPanel.Dock="Left"
                    Width="28"
                    Height="28"
                    Click="MuteBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Padding="0"
                    Margin="0,0,2,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <TextBlock x:Name="SpeakerIcon"
                           Text="&#xE767;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="14"
                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Button>

            <Slider x:Name="VolumeSlider"
                    Style="{StaticResource VolumeSliderStyle}"
                    Width="118"
                    Margin="0,0,2,0"
                    VerticalAlignment="Center"
                    Value="{Binding Volume, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ValueChanged="VolumeSlider_ValueChanged"
                    PreviewMouseDown="VolumeSlider_PreviewMouseDown"
                    PreviewMouseMove="VolumeSlider_PreviewMouseMove"
                    PreviewMouseUp="VolumeSlider_PreviewMouseUp"/>
        </DockPanel>
    </Border>
</UserControl>
