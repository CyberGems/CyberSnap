<Window x:Class="CyberSnap.UI.Editor.EditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        Title="Annotations Editor"
        Height="920" Width="1400"
        MinHeight="920" MinWidth="1400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="pack://application:,,,/CyberSnap.ico"
        SourceInitialized="OnSourceInitialized">

    <Window.Resources>
        <!-- Custom Color Brushes matching EditorColors -->
        <SolidColorBrush x:Key="BgPrimaryBrush" Color="#0D0F17"/>
        <SolidColorBrush x:Key="BgSecondaryBrush" Color="#12141F"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="#171A28"/>
        <SolidColorBrush x:Key="BgHoverBrush" Color="#21263A"/>
        <SolidColorBrush x:Key="CanvasBgBrush" Color="#080A10"/>
        <SolidColorBrush x:Key="TitleBarBrush" Color="#060C14"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6F0FF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0B4D2"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6E82A0"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#00FFFF"/>
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#1C2030"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#262A40"/>

        <!-- Premium Button Style for Top Bar Action Buttons -->
        <Style x:Key="TopBarButton" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="BtnIcon" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="12" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSecondaryBrush}"/>
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97" CenterX="20" CenterY="10"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Premium Button Style for Draw Tools -->
        <Style x:Key="ToolButton" TargetType="ToggleButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="6">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="ToolIcon" Width="16" Height="16" Margin="0,0,8,0" Stretch="Uniform"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="11.5" FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer Window Border for rounding and resizing -->
    <Border x:Name="WindowBorder" CornerRadius="12" BorderThickness="1"
            BorderBrush="{StaticResource BorderBrush}" Background="{StaticResource BgPrimaryBrush}" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- TitleBar -->
                <RowDefinition Height="Auto"/> <!-- Top Actions Bar -->
                <RowDefinition Height="*"/>    <!-- Main Layout -->
                <RowDefinition Height="Auto"/> <!-- Status Bar -->
            </Grid.RowDefinitions>

            <!-- WPF Custom TitleBar -->
            <controls:CyberSnapTitleBar Grid.Row="0" x:Name="EditorTitleBar"
                                      Title="CyberSnap - Annotations Editor"
                                      CloseRequested="TitleBar_CloseRequested"/>

            <!-- Top Actions Toolbar (Save, Save As, Undo, Redo, Copy, Paste, Open) -->
            <Border Grid.Row="1" Height="76" Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1"
                    Padding="22,13,18,12">
                <DockPanel LastChildFill="False">
                    <!-- Brand Section (Left side inside toolbar) -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/Assets/CyberSnap_square.png" Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform"/>
                        <TextBlock Text="CyberSnap" Foreground="{StaticResource AccentBrush}" FontSize="13.5" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Annotations Editor" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Action Buttons (Right side aligned, ordered Right-to-Left visually) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnUndo" Content="Undo" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,8,0" Click="BtnUndo_Click"/>
                        <Button x:Name="BtnRedo" Content="Redo" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,16,0" Click="BtnRedo_Click"/>
                        <Button x:Name="BtnOpen" Content="Open" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,8,0" Click="BtnOpen_Click"/>
                        <Button x:Name="BtnPaste" Content="Paste" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,8,0" Click="BtnPaste_Click"/>
                        <Button x:Name="BtnCopy" Content="Copy" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,8,0" Click="BtnCopy_Click"/>
                        <Button x:Name="BtnSave" Content="Save" Style="{StaticResource TopBarButton}" Width="95" Margin="0,0,8,0" Click="BtnSave_Click"/>
                        <Button x:Name="BtnSaveAs" Content="Save As" Style="{StaticResource TopBarButton}" Width="120" Click="BtnSaveAs_Click"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Main Work Area -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="332"/> <!-- Toolbar -->
                    <ColumnDefinition Width="*"/>    <!-- Canvas Container -->
                </Grid.ColumnDefinitions>

                <!-- Left-side Toolbar Panel -->
                <Border Grid.Column="0" Background="{StaticResource BgSecondaryBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0"
                        Padding="20,18">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/> <!-- Tools Grid -->
                            <RowDefinition Height="Auto"/> <!-- Separator / Color & Width Grid -->
                        </Grid.RowDefinitions>

                        <!-- Tools Section -->
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Tools" Foreground="{StaticResource AccentBrush}" FontSize="13.5" FontWeight="Bold" Margin="0,0,0,12"/>
                            
                            <!-- Navigation/Utility tools (Grid layout) -->
                            <Grid Height="80" Margin="0,0,0,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <ToggleButton Grid.Row="0" Grid.Column="0" x:Name="ToolPan" Content="Pan" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="0" Grid.Column="1" x:Name="ToolSelect" Content="Select" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="1" Grid.Column="0" x:Name="ToolCrop" Content="Crop" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="1" Grid.Column="1" x:Name="ToolEraser" Content="Eraser" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                            </Grid>

                            <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,4,0,12"/>

                            <!-- Drawing/Annotation tools (Grid layout) -->
                            <Grid Height="160">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <ToggleButton Grid.Row="0" Grid.Column="0" x:Name="ToolDraw" Content="Draw" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="0" Grid.Column="1" x:Name="ToolArrow" Content="Arrow" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="0" Grid.Column="2" x:Name="ToolCurved" Content="Curved" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>

                                <ToggleButton Grid.Row="1" Grid.Column="0" x:Name="ToolLine" Content="Line" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="1" Grid.Column="1" x:Name="ToolRect" Content="Rectangle" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="1" Grid.Column="2" x:Name="ToolCircle" Content="Circle" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>

                                <ToggleButton Grid.Row="2" Grid.Column="0" x:Name="ToolText" Content="Text" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="2" Grid.Column="1" x:Name="ToolHighlight" Content="Highlight" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="2" Grid.Column="2" x:Name="ToolBlur" Content="Blur" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>

                                <ToggleButton Grid.Row="3" Grid.Column="0" x:Name="ToolStep" Content="Step" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="3" Grid.Column="1" x:Name="ToolMagnifier" Content="Magnifier" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                                <ToggleButton Grid.Row="3" Grid.Column="2" x:Name="ToolEmoji" Content="Emoji" Style="{StaticResource ToolButton}" Checked="Tool_Checked"/>
                            </Grid>
                        </StackPanel>

                        <!-- Color & Width Section -->
                        <StackPanel Grid.Row="1" Margin="0,18,0,0">
                            <TextBlock Text="Color &amp; Width" Foreground="{StaticResource AccentBrush}" FontSize="13.5" FontWeight="Bold" Margin="0,0,0,12"/>
                            
                            <!-- Color Swatches Grid -->
                            <UniformGrid Columns="6" Rows="2" x:Name="SwatchesGrid" Margin="0,0,0,12">
                                <!-- Populated dynamically in code-behind -->
                            </UniformGrid>

                            <!-- Stroke Widths Panel -->
                            <UniformGrid Columns="5" Rows="1" x:Name="StrokeWidthGrid">
                                <!-- Populated dynamically in code-behind -->
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Hosted Canvas Panel (Canvas + Rulers inside WindowsFormsHost) -->
                <Border Grid.Column="1" Background="{StaticResource CanvasBgBrush}" Padding="18">
                    <!-- Hosted Windows Forms Content -->
                    <Border x:Name="CanvasInnerBorder" Background="{StaticResource CanvasBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
                        <!-- We host the WinForms AnnotationCanvas here in code-behind using WindowsFormsHost -->
                        <WindowsFormsHost x:Name="CanvasHost"/>
                    </Border>
                </Border>
            </Grid>

            <!-- Bottom Status Bar -->
            <Border Grid.Row="3" Height="58" Background="{StaticResource TitleBarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="18,8">
                <DockPanel LastChildFill="True">
                    <!-- Left Side Status items (Coordinates, Dimensions, File Name) -->
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Cursor Coordinates -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Image x:Name="CoordsIcon" Width="20" Height="20" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblCoords" Text="0, 0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14.5" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <!-- Separator -->
                        <Border Width="1" Height="16" Background="#28FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <!-- Resolution Dimensions -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                            <Image x:Name="DimsIcon" Width="20" Height="20" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblDims" Text="0 x 0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14.5" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                            <TextBlock Text=" px" Foreground="{StaticResource AccentBrush}" FontSize="14.5" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Width="1" Height="16" Background="#28FFFFFF" VerticalAlignment="Center" Margin="0,0,16,0"/>

                        <!-- File name -->
                        <StackPanel Orientation="Horizontal">
                            <Image x:Name="FileIcon" Width="20" Height="20" Margin="0,0,6,0" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock x:Name="LblFileName" Text="Unsaved capture" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14.5" FontFamily="Consolas" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right Side Zoom Panel & Controls (Ordered Left-to-Right Visually) -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Hint Label -->
                        <TextBlock x:Name="LblHint" Text="Ready" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,12,0" HorizontalAlignment="Right"/>
                        
                        <!-- Zoom Panel (Grouped in Border) -->
                        <Border Background="{StaticResource TitleBarBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="6" Height="42" Width="325" Padding="8,3" Margin="0,0,10,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="65"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Grid.Column="0" Text="Zoom" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12.5" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                <Slider Grid.Column="1" x:Name="SldZoom" Minimum="10" Maximum="800" Value="100" VerticalAlignment="Center" Margin="8,0" ValueChanged="SldZoom_ValueChanged"/>
                                <TextBlock Grid.Column="2" x:Name="LblZoom" Text="100%" Foreground="{StaticResource AccentBrush}" FontSize="13.5" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <!-- Reset Zoom (100%) Button -->
                        <Button x:Name="BtnResetZoom" Style="{StaticResource TopBarButton}" Height="42" Width="100" Margin="0,0,10,0" Click="BtnResetZoom_Click">
                            <Button.Content>
                                <TextBlock Text="100%" VerticalAlignment="Center"/>
                            </Button.Content>
                        </Button>

                        <!-- Fit Zoom Button -->
                        <Button x:Name="BtnFitZoom" Style="{StaticResource TopBarButton}" Height="42" Width="90" Margin="0,0,10,0" Click="BtnFitZoom_Click">
                            <Button.Content>
                                <TextBlock Text="Fit" VerticalAlignment="Center"/>
                            </Button.Content>
                        </Button>

                        <!-- Auto-fit Toggle -->
                        <StackPanel Orientation="Horizontal" Height="42" VerticalAlignment="Center">
                            <TextBlock Text="Auto-fit" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5" FontFamily="Segoe UI" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="ChkAutoFit" VerticalAlignment="Center" Checked="ChkAutoFit_Changed" Unchecked="ChkAutoFit_Changed"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
