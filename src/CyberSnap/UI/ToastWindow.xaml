<Window x:Class="CyberSnap.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        UseLayoutRounding="True"
        Focusable="False"
        ShowActivated="False">

    <Border x:Name="OuterShell"
            CornerRadius="12"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            SnapsToDevicePixels="True">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="DragScale" ScaleX="1" ScaleY="1"/>
                <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
            </TransformGroup>
        </Border.RenderTransform>

        <!-- Shadow plate (behind) + EdgeRing (1px solid ring via Padding, not BorderThickness).
             The padding-ring technique avoids WPF's soft anti-aliased Border stroke on curves. -->
        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
        <Border x:Name="ShadowPlate"
                CornerRadius="10"
                Background="Transparent"
                IsHitTestVisible="False"
                SnapsToDevicePixels="True"/>

        <Border x:Name="EdgeRing"
                CornerRadius="10"
                Background="Transparent"
                BorderThickness="0"
                Padding="0"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
        <Border x:Name="Root" CornerRadius="10" ClipToBounds="True"
                MaxWidth="360" MinWidth="196"
                SnapsToDevicePixels="True"
                UseLayoutRounding="True">
            <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TopProgressRow" Height="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition x:Name="BottomProgressRow" Height="4"/>
            </Grid.RowDefinitions>

            <Grid x:Name="ContentGrid" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid x:Name="ImageArea" Grid.Row="0" Visibility="Collapsed" MaxHeight="176" HorizontalAlignment="Stretch">
                    <Border x:Name="ImageFrame" CornerRadius="10,10,0,0" ClipToBounds="True">
                        <Grid>
                            <Image x:Name="PreviewImage" Stretch="Uniform"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                            <!-- Neutral play badge for video/GIF capture notifications (matches designer mock). -->
                            <Border x:Name="VideoPlayBadge"
                                    Width="40" Height="40" CornerRadius="20"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    IsHitTestVisible="False" Visibility="Collapsed"
                                    Background="#B4000000">
                                <Path Data="M8,5 L8,19 L19,12 Z"
                                      Fill="White" Stretch="Uniform"
                                      Width="15" Height="15"
                                      Margin="2,0,0,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel x:Name="ActionsHost" Grid.Row="2" Visibility="Collapsed">
                    <Border x:Name="PreviewActionsDivider" Height="1" Margin="10,0,10,6" Opacity="1"/>
                    <Grid x:Name="ActionsPanel" Margin="10,0,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="0"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="PinBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Pin preview"
                            AutomationProperties.Name="Pin preview"
                            AutomationProperties.HelpText="Keep this preview open."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="PinBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="PinIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="CloseBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Close preview"
                            AutomationProperties.Name="Close preview"
                            AutomationProperties.HelpText="Close this preview."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CloseBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="CloseIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="SaveBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Save preview"
                            AutomationProperties.Name="Save preview"
                            AutomationProperties.HelpText="Save this preview image."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="SaveBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="SaveIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="CopyBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Copy to clipboard"
                            AutomationProperties.Name="Copy to clipboard"
                            AutomationProperties.HelpText="Copy this preview to the clipboard."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CopyBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="CopyIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="ShareBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Share"
                            AutomationProperties.Name="Share"
                            AutomationProperties.HelpText="Upload and copy a shareable link."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="ShareBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="ShareIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="DeleteBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Delete file"
                            AutomationProperties.Name="Delete file"
                            AutomationProperties.HelpText="Delete the saved file for this preview."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="DeleteBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="DeleteIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="HistoryBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Open the Gallery Window"
                            AutomationProperties.Name="Open the Gallery Window"
                            AutomationProperties.HelpText="Open the Gallery Window."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="HistoryBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="HistoryIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border x:Name="EditBtn" Width="32" Height="32" CornerRadius="8"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Edit preview"
                            AutomationProperties.Name="Edit preview"
                            AutomationProperties.HelpText="Open this preview in the post-capture editor."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="EditBtn_KeyDown"
                            Opacity="1" Visibility="Collapsed">
                        <Image x:Name="EditIcon" Width="16" Height="16" Stretch="Uniform" Opacity="1"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
                </StackPanel>

                <Grid x:Name="TextContentPanel" Grid.Row="1" Margin="14,11,14,11">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="ColorSwatch" Grid.Column="0" Width="28" Height="28" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"
                            BorderBrush="#44FFFFFF" BorderThickness="1"/>
                    <Border x:Name="InlinePreviewHost" Grid.Column="1" Width="44" Height="44" CornerRadius="8"
                            Margin="0,0,12,0" Visibility="Collapsed" VerticalAlignment="Center"
                            Background="#12FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Image x:Name="InlinePreviewImage" Stretch="Uniform" Margin="4"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" FontSize="12.75" FontWeight="SemiBold"
                                   FontFamily="Segoe UI Variable Text" TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="Toast title"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock x:Name="BodyText" FontSize="11.5" Opacity="0.72" TextWrapping="Wrap"
                                   FontFamily="Segoe UI Variable Text" TextAlignment="Center"
                                   MaxWidth="292" Margin="0,2,0,0"
                                   ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.Name="Toast message"
                                   AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                    <Border x:Name="TextCloseBtn" Grid.Column="3" Width="22" Height="22" CornerRadius="6"
                            Background="Transparent" BorderBrush="Transparent" BorderThickness="0"
                            ToolTip="Close notification"
                            AutomationProperties.Name="Close notification"
                            AutomationProperties.HelpText="Close this notification."
                            Cursor="Hand"
                            Focusable="True"
                            KeyDown="CloseBtn_KeyDown"
                            VerticalAlignment="Top" Margin="10,-2,-4,0"
                            Visibility="Collapsed">
                        <Image x:Name="TextCloseIcon" Width="11" Height="11" Stretch="Uniform" Opacity="0.78"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>

            <Grid x:Name="ProgressHost" Grid.Row="2" ClipToBounds="True">
                <Border x:Name="ProgressTrack"
                        Background="Transparent"
                        HorizontalAlignment="Stretch"/>
                <Border x:Name="ProgressBar"
                        HorizontalAlignment="Stretch"
                        RenderTransformOrigin="0,0.5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                            <GradientStop Color="#FF00F2FF" Offset="0.0"/> <!-- Cyber Cyan -->
                            <GradientStop Color="#FF7A00FF" Offset="0.5"/> <!-- Cyber Purple -->
                            <GradientStop Color="#FFFF00D0" Offset="1.0"/> <!-- Cyber Magenta -->
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect x:Name="ProgressGlow" Color="#FF7A00FF" BlurRadius="8" ShadowDepth="0" Opacity="0.8"/>
                    </Border.Effect>
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ProgressScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                </Border>
            </Grid>
            </Grid>
        </Border>
        </Border>
        </Grid>
    </Border>
</Window>
