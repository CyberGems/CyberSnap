<Window x:Class="CyberSnap.UI.VideoTrimmerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        Title="Video &amp; GIF Trimmer"
        Height="560" Width="720"
        MinHeight="450" MinWidth="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeCardBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        Topmost="False"
        Icon="pack://application:,,,/CyberSnap.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Background="{DynamicResource ThemeCardBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/> <!-- Timeline Row -->
                <RowDefinition Height="Auto"/> <!-- Playback controls -->
                <RowDefinition Height="Auto"/> <!-- Crop Range Text -->
                <RowDefinition Height="Auto"/> <!-- Action Buttons -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar with Pin Button -->
            <controls:CyberSnapTitleBar x:Name="TrimmerTitleBar" Grid.Row="0"
                                        Title="Video &amp; GIF Trimmer"
                                        ShowPinButton="True"
                                        CloseRequested="TitleBar_CloseRequested"
                                        PinRequested="TitleBar_PinRequested"/>

            <!-- Video Player Area -->
            <Grid Grid.Row="1" Background="#FF000000" Margin="12,4,12,8">
                <MediaElement x:Name="MediaPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual" ScrubbingEnabled="True"
                              MediaOpened="MediaPlayer_MediaOpened" MediaEnded="MediaPlayer_MediaEnded"/>
                <!-- Loading / Exporting Overlay -->
                <Grid x:Name="ProgressOverlay" Background="#B0000000" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar x:Name="ExportProgressBar" IsIndeterminate="True" Width="200" Height="6" Margin="0,0,0,12"/>
                        <TextBlock x:Name="ProgressText" Text="Exporting..." Foreground="{DynamicResource ThemeTextPrimaryBrush}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Timeline and Seek Row (Integrated Buttons & Slider) -->
            <Grid Grid.Row="2" Margin="12,0,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Set Start Button -->
                    <ColumnDefinition Width="*"/>    <!-- Slider & Range Bar Container -->
                    <ColumnDefinition Width="Auto"/> <!-- Set End Button -->
                    <ColumnDefinition Width="90"/>   <!-- Time Labels (Fixed width prevents dancing buttons) -->
                </Grid.ColumnDefinitions>
                
                <!-- Set Start Button -->
                <Button x:Name="SetStartBtn" Grid.Column="0" Content="Set Start" Padding="12,6" Click="SetStartBtn_Click"
                        ToolTip="Set the current time as the crop start position"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0"/>

                <!-- Slider & Range Bar Container -->
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Slider x:Name="TimeSlider" Grid.Row="0" VerticalAlignment="Center" 
                            Minimum="0" Maximum="1" Value="0"
                            FocusVisualStyle="{x:Null}"
                            PreviewMouseDown="TimeSlider_PreviewMouseDown" PreviewMouseUp="TimeSlider_PreviewMouseUp"
                            LostMouseCapture="TimeSlider_LostMouseCapture"
                            ValueChanged="TimeSlider_ValueChanged" Cursor="Hand"/>
                            
                    <!-- Tri-color Range Background Bar (Red = cut, Green = keep) -->
                    <Border Grid.Row="1" Height="5" CornerRadius="2.5" ClipToBounds="True" Margin="2,-2,2,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ColStartCut" Width="0*"/>
                                <ColumnDefinition x:Name="ColKeep" Width="1*"/>
                                <ColumnDefinition x:Name="ColEndCut" Width="0*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#99D32F2F"/>
                            <Border Grid.Column="1" Background="#99388E3C"/>
                            <Border Grid.Column="2" Background="#99D32F2F"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Set End Button -->
                <Button x:Name="SetEndBtn" Grid.Column="2" Content="Set End" Padding="12,6" Click="SetEndBtn_Click"
                        ToolTip="Set the current time as the crop end position"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0"/>

                <!-- Time Status Labels -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock x:Name="TimeStatusText" Text="00:00" Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontSize="11.5" FontWeight="SemiBold"/>
                    <TextBlock Text=" / " Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11.5"/>
                    <TextBlock x:Name="DurationStatusText" Text="00:00" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11.5"/>
                </StackPanel>
            </Grid>

            <!-- Playback Controls (Play/Pause, Frame Steps) + Volume -->
            <Grid Grid.Row="3" Margin="0,4,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Step Backward -->
                <Button x:Name="StepBackBtn" Width="36" Height="36" Click="StepBackBtn_Click" Margin="0,0,12,0"
                        ToolTip="Step Backward"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Path Data="M 13,6 L 5,10 L 13,14 Z M 16,6 L 18,6 L 18,14 L 16,14 Z M 20,6 L 22,6 L 22,14 L 20,14 Z" 
                          Fill="{DynamicResource ThemeTextPrimaryBrush}" Stretch="Uniform" Width="13" Height="13"/>
                </Button>

                <!-- Play / Pause -->
                <Button x:Name="PlayPauseBtn" Width="52" Height="52" Click="PlayPauseBtn_Click"
                        ToolTip="Pause"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="26">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock x:Name="PlayPauseIconText" Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="2,0,0,0"/>
                </Button>

                <!-- Step Forward -->
                <Button x:Name="StepForwardBtn" Width="36" Height="36" Click="StepForwardBtn_Click" Margin="12,0,0,0"
                        ToolTip="Step Forward"
                        Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Path Data="M 5,6 L 7,6 L 7,14 L 5,14 Z M 9,6 L 11,6 L 11,14 L 9,14 Z M 14,6 L 22,10 L 14,14 Z" 
                          Fill="{DynamicResource ThemeTextPrimaryBrush}" Stretch="Uniform" Width="13" Height="13"/>
                </Button>
                </StackPanel>

                <controls:MediaVolumeControl x:Name="VolumeControl"
                                             Grid.Column="0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Margin="12,0,0,0"
                                             VolumeChanged="VolumeControl_VolumeChanged"
                                             ExportMuteChanged="VolumeControl_ExportMuteChanged"/>
            </Grid>

            <!-- Centered Crop Selection Status Text as capsule chips -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,8">
                <!-- Start Chip -->
                <Border CornerRadius="14" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" Padding="10,4" 
                        Cursor="Hand" MouseDown="StartPointText_MouseDown" ToolTip="Click to seek to start position">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock x:Name="StartPointText" Text="Start: 00:00.0" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Border>
                
                <TextBlock Text="   " FontSize="12" VerticalAlignment="Center"/>
                
                <!-- End Chip -->
                <Border CornerRadius="14" Background="#15FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" Padding="10,4" 
                        Cursor="Hand" MouseDown="EndPointText_MouseDown" ToolTip="Click to seek to end position">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock x:Name="EndPointText" Text="End: 00:00.0" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Action Buttons Panel (Visible/Enabled when trimmed) -->
            <Border Grid.Row="5" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ThemeSeparatorBrush}" Padding="12,12,12,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="CancelBtn" Grid.Column="0" Content="Cancelar" Padding="16,8" Click="CancelBtn_Click" Visibility="Collapsed"
                            ToolTip="Reset crop range"
                            Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="Transparent"
                            BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" Visibility="Collapsed" x:Name="SaveActionPanel">
                        <Button x:Name="SaveAsNewBtn" Content="Save As New" Padding="16,8" Margin="0,0,12,0" Click="SaveAsNewBtn_Click"
                                ToolTip="Save the trimmed video as a new file"
                                Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold"/>
                        
                        <Button x:Name="TrimBtn" Content="Cortar" Padding="20,8" Click="TrimBtn_Click"
                                ToolTip="Overwrite the original file with the trimmed version"
                                Foreground="{DynamicResource ThemeTextPrimaryBrush}" Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1" Cursor="Hand" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
