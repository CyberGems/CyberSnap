<Window x:Class="CyberSnap.UI.VideoTrimmerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        Title="Video &amp; GIF Trimmer"
        Height="560" Width="720"
        MinHeight="450" MinWidth="600"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{DynamicResource ThemeCardBrush}"
        WindowStyle="None"
        AllowsTransparency="False"
        Topmost="False"
        Icon="pack://application:,,,/CyberSnap.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>

        <Style x:Key="TrimmerChipBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <Style x:Key="TrimmerChipButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#24FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrimmerMarkerButtonStyle" TargetType="Button" BasedOn="{StaticResource TrimmerChipButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="TrimmerSeekButtonStyle" TargetType="Button" BasedOn="{StaticResource TrimmerChipButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="MinWidth" Value="52"/>
        </Style>

        <Style x:Key="TrimmerFlatButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrimmerRoundButtonStyle" TargetType="Button" BasedOn="{StaticResource TrimmerFlatButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrimmerPlayButtonStyle" TargetType="Button" BasedOn="{StaticResource TrimmerFlatButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="26"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrimmerTimerToggleStyle" TargetType="Button">
            <Setter Property="Background" Value="#01000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="8"
                                Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                BorderThickness="1"
                                Padding="10,4"
                                HorizontalAlignment="Center">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeSliderRepeatButton" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Height="24" Margin="6,0,6,0">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Style="{StaticResource TimeSliderRepeatButton}"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Style="{StaticResource TimeSliderRepeatButton}"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14"
                                           Height="14"
                                           FocusVisualStyle="{x:Null}"
                                           VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{DynamicResource ThemeTextPrimaryBrush}"
                                                         Stroke="{DynamicResource ThemeTextSecondaryBrush}"
                                                         StrokeThickness="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Margin="1" CornerRadius="12">
    <Border x:Name="RootBorder" CornerRadius="12" ClipToBounds="True" SnapsToDevicePixels="True" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/> <!-- Timeline Row -->
                <RowDefinition Height="Auto"/> <!-- Playback controls + actions -->
            </Grid.RowDefinitions>

            <!-- Custom Title Bar with Pin Button -->
            <controls:CyberSnapTitleBar x:Name="TrimmerTitleBar" Grid.Row="0"
                                        Title="Video &amp; GIF Trimmer"
                                        ShowPinButton="True"
                                        CloseRequested="TitleBar_CloseRequested"
                                        PinRequested="TitleBar_PinRequested"/>

            <!-- Video Player Area -->
            <Grid Grid.Row="1" Background="#FF000000" Margin="12,4,12,8">
                <MediaElement x:Name="MediaPlayer" LoadedBehavior="Manual" UnloadedBehavior="Manual" ScrubbingEnabled="True"
                              MediaOpened="MediaPlayer_MediaOpened" MediaEnded="MediaPlayer_MediaEnded"/>
                <!-- Loading / Exporting Overlay -->
                <Grid x:Name="ProgressOverlay" Background="#B0000000" Visibility="Collapsed">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar x:Name="ExportProgressBar" IsIndeterminate="True" Width="200" Height="6" Margin="0,0,0,12"/>
                        <TextBlock x:Name="ProgressText" Text="Exporting..." Foreground="{DynamicResource ThemeTextPrimaryBrush}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- Timeline and Seek Row (Integrated Buttons & Slider) -->
            <Grid Grid.Row="2" Margin="12,0,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource TrimmerChipBorderStyle}"
                        MinWidth="118"
                        Padding="3"
                        Margin="0,0,10,0">
                    <Grid MinHeight="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartSeekBtn"
                                Grid.Column="0"
                                Click="StartSeekBtn_Click"
                                ToolTip="Click to seek to start position"
                                Style="{StaticResource TrimmerSeekButtonStyle}">
                            <TextBlock x:Name="StartPointText"
                                       Text="00:00.0"
                                       IsHitTestVisible="False"/>
                        </Button>
                        <Border Grid.Column="1"
                                Width="1"
                                Height="16"
                                Background="{DynamicResource ThemeSeparatorBrush}"
                                Margin="2,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="SetStartBtn"
                                Grid.Column="2"
                                Content="Set Start"
                                Click="SetStartBtn_Click"
                                ToolTip="Set the current time as the crop start position"
                                Style="{StaticResource TrimmerMarkerButtonStyle}"/>
                    </Grid>
                </Border>

                <!-- Slider with integrated range track (red/green segments behind thumb) -->
                <Grid Grid.Column="1" VerticalAlignment="Center" Margin="0,0,10,0" Height="24">
                    <Border VerticalAlignment="Center"
                            Height="6"
                            CornerRadius="3"
                            ClipToBounds="True"
                            Margin="6,0,6,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="ColStartCut" Width="0*"/>
                                <ColumnDefinition x:Name="ColKeep" Width="1*"/>
                                <ColumnDefinition x:Name="ColEndCut" Width="0*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#99D32F2F"/>
                            <Border Grid.Column="1" Background="#99388E3C"/>
                            <Border Grid.Column="2" Background="#99D32F2F"/>
                        </Grid>
                    </Border>

                    <Slider x:Name="TimeSlider"
                            Style="{StaticResource TimeSliderStyle}"
                            VerticalAlignment="Center"
                            Minimum="0"
                            Maximum="1"
                            Value="0"
                            PreviewMouseDown="TimeSlider_PreviewMouseDown"
                            PreviewMouseUp="TimeSlider_PreviewMouseUp"
                            LostMouseCapture="TimeSlider_LostMouseCapture"
                            ValueChanged="TimeSlider_ValueChanged"
                            Cursor="Hand"/>
                </Grid>

                <!-- Set End marker -->
                <Border Grid.Column="2"
                        Style="{StaticResource TrimmerChipBorderStyle}"
                        MinWidth="118"
                        Padding="3">
                    <Grid MinHeight="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SetEndBtn"
                                Grid.Column="0"
                                Content="Set End"
                                Click="SetEndBtn_Click"
                                ToolTip="Set the current time as the crop end position"
                                Style="{StaticResource TrimmerMarkerButtonStyle}"/>
                        <Border Grid.Column="1"
                                Width="1"
                                Height="16"
                                Background="{DynamicResource ThemeSeparatorBrush}"
                                Margin="2,0"
                                VerticalAlignment="Center"/>
                        <Button x:Name="EndSeekBtn"
                                Grid.Column="2"
                                Click="EndSeekBtn_Click"
                                ToolTip="Click to seek to end position"
                                Style="{StaticResource TrimmerSeekButtonStyle}">
                            <TextBlock x:Name="EndPointText"
                                       Text="00:00.0"
                                       IsHitTestVisible="False"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- Playback Controls (Play/Pause, Frame Steps) + Volume -->
            <Grid Grid.Row="3" Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Height="1"
                        Background="{DynamicResource ThemeSeparatorBrush}"
                        Margin="12,0,12,10"/>

                <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <Button x:Name="PlaybackTimeBtn"
                            Click="PlaybackTimeBtn_Click"
                            ToolTip="Click to toggle time display"
                            Style="{StaticResource TrimmerTimerToggleStyle}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TimeStatusText"
                                       Text="00:00"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TimeStatusSeparator"
                                       Text="·"
                                       Foreground="{DynamicResource ThemeMutedBrush}"
                                       FontSize="11.5"
                                       Margin="8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="DurationStatusText"
                                       Text="00:00"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Step Backward -->
                <Button x:Name="StepBackBtn" Width="36" Height="36" Click="StepBackBtn_Click" Margin="0,0,12,0"
                        ToolTip="Step Backward"
                        Style="{StaticResource TrimmerRoundButtonStyle}">
                    <Path Data="M 13,6 L 5,10 L 13,14 Z M 16,6 L 18,6 L 18,14 L 16,14 Z M 20,6 L 22,6 L 22,14 L 20,14 Z" 
                          Fill="{DynamicResource ThemeTextPrimaryBrush}" Stretch="Uniform" Width="13" Height="13"/>
                </Button>

                <!-- Play / Pause -->
                <Button x:Name="PlayPauseBtn" Width="52" Height="52" Click="PlayPauseBtn_Click"
                        ToolTip="Pause"
                        Style="{StaticResource TrimmerPlayButtonStyle}">
                    <TextBlock x:Name="PlayPauseIconText" Text="&#xE769;" FontFamily="Segoe MDL2 Assets" FontSize="18" Margin="2,0,0,0"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                </Button>

                <!-- Step Forward -->
                <Button x:Name="StepForwardBtn" Width="36" Height="36" Click="StepForwardBtn_Click" Margin="12,0,0,0"
                        ToolTip="Step Forward"
                        Style="{StaticResource TrimmerRoundButtonStyle}">
                    <Path Data="M 5,6 L 7,6 L 7,14 L 5,14 Z M 9,6 L 11,6 L 11,14 L 9,14 Z M 14,6 L 22,10 L 14,14 Z" 
                          Fill="{DynamicResource ThemeTextPrimaryBrush}" Stretch="Uniform" Width="13" Height="13"/>
                </Button>
                    </StackPanel>
                </StackPanel>

                <controls:MediaVolumeControl x:Name="VolumeControl"
                                             Grid.Column="0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center"
                                             Margin="12,0,0,0"
                                             VolumeChanged="VolumeControl_VolumeChanged"
                                             ExportMuteChanged="VolumeControl_ExportMuteChanged"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <Border x:Name="TrimBtnHost"
                            ClipToBounds="True"
                            VerticalAlignment="Center"
                            MaxWidth="0"
                            Opacity="0">
                        <Button x:Name="TrimBtn"
                                Content="Cortar"
                                Padding="20,8"
                                Margin="0,0,12,0"
                                Click="TrimBtn_Click"
                                ToolTip="Overwrite the original file with the trimmed version"
                                Style="{StaticResource TrimmerFlatButtonStyle}"
                                FontWeight="Bold"
                                IsEnabled="False"/>
                    </Border>

                    <Button x:Name="SaveAsNewBtn"
                            Content="Save As New"
                            Padding="16,8"
                            Click="SaveAsNewBtn_Click"
                            ToolTip="Save the trimmed video as a new file"
                            Style="{StaticResource TrimmerFlatButtonStyle}"
                            FontWeight="SemiBold"/>
                </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
    </Border>
</Window>
