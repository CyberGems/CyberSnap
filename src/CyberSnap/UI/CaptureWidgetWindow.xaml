<Window x:Class="CyberSnap.UI.CaptureWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSnap Quick Panel"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <!-- CyberGems / Cyberpunk Styles -->
        <SolidColorBrush x:Key="WidgetBg" Color="#0D0F1A" Opacity="0.95"/>
        <SolidColorBrush x:Key="WidgetAccent" Color="#00FFFF"/>
        <SolidColorBrush x:Key="WidgetAccentHover" Color="#80FFFF"/>
        <SolidColorBrush x:Key="WidgetText" Color="#E6F0FF"/>
        <SolidColorBrush x:Key="WidgetTextMuted" Color="#A0B4D2"/>
        <SolidColorBrush x:Key="WidgetBorder" Color="#2000FFFF"/>
        <SolidColorBrush x:Key="WidgetBorderActive" Color="#8000FFFF"/>
        <SolidColorBrush x:Key="CaptureBtnRed" Color="#FF3B30"/>
        
        <!-- Glow Effect -->
        <DropShadowEffect x:Key="CyanGlow" Color="#00FFFF" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
        <DropShadowEffect x:Key="RedGlow" Color="#FF3B30" BlurRadius="12" ShadowDepth="0" Opacity="0.7"/>

        <!-- Action Button Style (Larger buttons/margins) -->
        <Style x:Key="WidgetActionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource WidgetText}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1500FFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3000FFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle Switch Style (Cyberpunk neon look) -->
        <Style x:Key="WidgetToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" Width="32" Height="18" CornerRadius="9"
                                    Background="#2A2A2A" BorderBrush="#444" BorderThickness="1"/>
                            <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7"
                                    Background="#888" HorizontalAlignment="Left" Margin="2,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource WidgetAccent}"/>
                                <Setter TargetName="Track" Property="BorderBrush" Value="{StaticResource WidgetAccent}"/>
                                <Setter TargetName="Thumb" Property="Background" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Thumb" Property="Background" Value="#AAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Main Container -->
    <Grid x:Name="RootGrid">
        <!-- RenderTransform for sliding animation -->
        <Grid.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="0" Y="0"/>
        </Grid.RenderTransform>

        <!-- The widget is one piece; it peeks from the selected screen edge when collapsed. -->
        <Grid x:Name="LayoutGrid">
            <!-- Main Panel Border -->
            <Border x:Name="MainPanelBorder" Background="{StaticResource WidgetBg}"
                    BorderBrush="{StaticResource WidgetBorderActive}" BorderThickness="1" CornerRadius="8"
                    Visibility="Visible">
                <Border.Effect>
                    <!-- Soft neutral drop shadow (SnagIt-like). Needs the transparent halo from
                         ShadowMargin to render; tune BlurRadius/Opacity/ShadowDepth to taste. -->
                    <DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Direction="270" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Border x:Name="PeekGrip" Background="#2600FFFF" BorderBrush="{StaticResource WidgetAccent}"
                            BorderThickness="0" Panel.ZIndex="2" IsHitTestVisible="False">
                        <!-- No own glow: the panel's drop shadow covers the peek. Its own effect
                             (clipped before the shadow margin existed) now rendered as a corner ghost. -->
                        <StackPanel x:Name="GripPanel" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Rectangle x:Name="GripRect1" Width="2" Height="6" Fill="{StaticResource WidgetTextMuted}" Margin="1,0"/>
                            <Rectangle x:Name="GripRect2" Width="2" Height="6" Fill="{StaticResource WidgetTextMuted}" Margin="1,0"/>
                            <Rectangle x:Name="GripRect3" Width="2" Height="6" Fill="{StaticResource WidgetTextMuted}" Margin="1,0"/>
                        </StackPanel>
                    </Border>

                <Grid x:Name="ControlsGrid" Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Capture Button -->
                        <RowDefinition Height="Auto"/> <!-- Quick Actions -->
                        <RowDefinition Height="Auto"/> <!-- Settings Row -->
                    </Grid.RowDefinitions>

                    <!-- Big Circular Capture Button -->
                    <Grid Grid.Row="0" Margin="0,0,0,12" HorizontalAlignment="Center">
                        <Button x:Name="CaptureButton" Click="CaptureButton_Click" Cursor="Hand" Width="54" Height="54" FocusVisualStyle="{x:Null}"
                                ToolTip="Quick screenshot (Area Capture)">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Grid Background="Transparent">
                                        <!-- Glow/Outer Ring -->
                                        <Path x:Name="OuterRing" Data="M4.5 3C3.67 3 3 3.67 3 4.5v2a.5.5 0 0 1-1 0v-2A2.5 2.5 0 0 1 4.5 2h2a.5.5 0 0 1 0 1h-2Zm0 14A1.5 1.5 0 0 1 3 15.5v-2a.5.5 0 0 0-1 0v2A2.5 2.5 0 0 0 4.5 18h2a.5.5 0 0 0 0-1h-2ZM17 4.5c0-.83-.67-1.5-1.5-1.5h-2a.5.5 0 0 1 0-1h2A2.5 2.5 0 0 1 18 4.5v2a.5.5 0 0 1-1 0v-2ZM15.5 17c.83 0 1.5-.67 1.5-1.5v-2a.5.5 0 0 1 1 0v2a2.5 2.5 0 0 1-2.5 2.5h-2a.5.5 0 0 1 0-1h2" Fill="{StaticResource WidgetAccent}" Stretch="Uniform" Width="54" Height="54"/>
                                        <!-- Center content: scales (A) + glow intensifies (B) on hover -->
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5">
                                            <ContentPresenter.RenderTransform>
                                                <ScaleTransform x:Name="CenterScale" ScaleX="1" ScaleY="1"/>
                                            </ContentPresenter.RenderTransform>
                                            <ContentPresenter.Effect>
                                                <DropShadowEffect x:Name="CenterGlow" Color="#00FFFF" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                                            </ContentPresenter.Effect>
                                        </ContentPresenter>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="OuterRing" Property="Effect" Value="{StaticResource CyanGlow}"/>
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <!-- A: subtle pop -->
                                                        <DoubleAnimation Storyboard.TargetName="CenterScale" Storyboard.TargetProperty="ScaleX"
                                                                         To="1.12" Duration="0:0:0.12">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="CenterScale" Storyboard.TargetProperty="ScaleY"
                                                                         To="1.12" Duration="0:0:0.12">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <!-- B: center glow intensifies -->
                                                        <DoubleAnimation Storyboard.TargetName="CenterGlow" Storyboard.TargetProperty="BlurRadius"
                                                                         To="16" Duration="0:0:0.12"/>
                                                        <DoubleAnimation Storyboard.TargetName="CenterGlow" Storyboard.TargetProperty="Opacity"
                                                                         To="1" Duration="0:0:0.12"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CenterScale" Storyboard.TargetProperty="ScaleX"
                                                                         To="1" Duration="0:0:0.18">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="CenterScale" Storyboard.TargetProperty="ScaleY"
                                                                         To="1" Duration="0:0:0.18">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="CenterGlow" Storyboard.TargetProperty="BlurRadius"
                                                                         To="8" Duration="0:0:0.18"/>
                                                        <DoubleAnimation Storyboard.TargetName="CenterGlow" Storyboard.TargetProperty="Opacity"
                                                                         To="0.7" Duration="0:0:0.18"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.7"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <!-- Big capture icon as content (glow now lives on the ContentPresenter so it can animate on hover) -->
                            <Image x:Name="BigCaptureIcon" Width="20" Height="20"/>
                        </Button>
                    </Grid>

                    <!-- Quick Action Shortcuts (Larger icons 22x22) -->
                    <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,2">
                            <Button Style="{StaticResource WidgetActionButton}" Click="ScrollCapture_Click" ToolTip="Scrolling capture">
                                <Image x:Name="ScrollCaptureIcon" Width="22" Height="22"/>
                            </Button>
                            <Button Style="{StaticResource WidgetActionButton}" Click="GrabText_Click" ToolTip="Extract text (OCR)">
                                <Image x:Name="GrabTextIcon" Width="22" Height="22"/>
                            </Button>
                            <Button Style="{StaticResource WidgetActionButton}" Click="ScreenRecord_Click" ToolTip="Record screen (Video MP4)">
                                <Image x:Name="ScreenRecordIcon" Width="22" Height="22"/>
                            </Button>
                            <Button Style="{StaticResource WidgetActionButton}" Click="GifRecord_Click" ToolTip="Record animated GIF">
                                <Image x:Name="GifRecordIcon" Width="22" Height="22"/>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Style="{StaticResource WidgetActionButton}" Click="ColorPicker_Click" ToolTip="Color picker">
                                <Image x:Name="ColorPickerIcon" Width="18" Height="18"/>
                            </Button>
                            <Button Style="{StaticResource WidgetActionButton}" Click="QrScan_Click" ToolTip="Scan QR / Barcode">
                                <Image x:Name="QrScanIcon" Width="22" Height="22"/>
                            </Button>
                            <Button Style="{StaticResource WidgetActionButton}" Click="Ruler_Click" ToolTip="Ruler">
                                <Image x:Name="RulerIcon" Width="22" Height="22"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Settings / Toggle Row -->
                    <Grid Grid.Row="2" Margin="0,4,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6" ToolTip="Open the post-capture editor for annotations after capturing.">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Enable editor" FontSize="11" Foreground="{StaticResource WidgetTextMuted}" FontFamily="Segoe UI Variable Text"
                                       Margin="0,0,8,0" VerticalAlignment="Center"
                                       ToolTip="Open the post-capture editor for annotations after capturing."/>
                            <ToggleButton x:Name="EnableEditorToggle" Grid.Column="1" Style="{StaticResource WidgetToggleSwitch}"
                                          Checked="EnableEditorToggle_Changed" Unchecked="EnableEditorToggle_Changed"
                                          ToolTip="Open the post-capture editor for annotations after capturing."/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Image Width="10" Height="10" Margin="0,0,4,0" VerticalAlignment="Center"
                                       Source="pack://application:,,,/Assets/CyberSnap_square.png"/>
                                <TextBlock Text="CyberSnap widget" FontSize="9.5" FontWeight="SemiBold"
                                           Foreground="{StaticResource WidgetTextMuted}" Opacity="0.65"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe UI Variable Display"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource WidgetActionButton}" Width="24" Height="24" Click="Settings_Click" ToolTip="Configuration">
                                <Image x:Name="SettingsIcon" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
