<Window x:Class="CyberSnap.UI.OcrResultWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        Title="Text extraction (OCR)"
        Height="520" Width="580"
        MinHeight="400" MinWidth="420"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Icon="pack://application:,,,/Assets/Icons/OCR.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>
        <SolidColorBrush x:Key="TranslationShimmerBrush" Color="#14FFFFFF"/>
        <!-- Accent tint for the translated-output box (overridden per-theme in ApplyTheme) -->
        <SolidColorBrush x:Key="TranslationTintBrush" Color="#1400FFFF"/>
        <SolidColorBrush x:Key="TranslationTintBorderBrush" Color="#2800FFFF"/>

        <Style x:Key="OcrThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="3"
                                Background="#66FFFFFF"
                                Margin="0,2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent" Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource OcrThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Width" Value="Auto"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OcrTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Malgun Gothic, Yu Gothic UI, Arial Unicode MS, Segoe UI Symbol"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Styled Combobox for language/engine selectors -->
        <Style x:Key="OcrComboStyle" TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="MaxDropDownHeight" Value="280"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleSite"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border x:Name="Bd"
                                        MinHeight="{TemplateBinding MinHeight}"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="16"/>
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter x:Name="ContentSite"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                          IsHitTestVisible="False"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                          Margin="0,0,4,0"/>
                                        <TextBox x:Name="PART_EditableTextBox"
                                                 Visibility="Collapsed"
                                                 Padding="0" Margin="0,0,4,0"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{TemplateBinding Foreground}"
                                                 CaretBrush="{TemplateBinding Foreground}"
                                                 FontSize="{TemplateBinding FontSize}"
                                                 VerticalAlignment="Center"
                                                 VerticalContentAlignment="Center"
                                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>
                                        <Path Grid.Column="1"
                                              Width="8" Height="4"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Data="M 0 0 L 4 4 L 8 0 Z"
                                              Fill="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Margin="0,3,0,0"
                                        Background="{DynamicResource ThemeCardBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        SnapsToDevicePixels="True">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.3" Color="Black"/>
                                    </Border.Effect>
                                    <ScrollViewer Padding="4"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#35FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEditable" Value="False">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrComboItemStyle" TargetType="ComboBoxItem">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,5"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#18FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared copy icon (Lucide "copy" outline) for the section-header action buttons -->
        <Geometry x:Key="CopyIconGeometry">M10,8 H20 A2,2 0 0 1 22,10 V20 A2,2 0 0 1 20,22 H10 A2,2 0 0 1 8,20 V10 A2,2 0 0 1 10,8 Z M4,16 A2,2 0 0 1 2,14 V4 A2,2 0 0 1 4,2 H14 A2,2 0 0 1 16,4</Geometry>

        <!-- Section header label ("Recognized text" / "Translation") -->
        <Style x:Key="OcrSectionHeaderText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Opacity" Value="0.85"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
        </Style>

        <!-- Compact ghost button used for the per-section Copy actions -->
        <Style x:Key="OcrHeaderActionButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="OcrSearchNavButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="MinWidth" Value="14"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="OcrContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrMenuItemStyle" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Grid MinWidth="168">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" ContentSource="Icon"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <ContentPresenter Grid.Column="1" ContentSource="Header"
                                                  RecognizesAccessKey="True" VerticalAlignment="Center"
                                                  Margin="8,0,18,0"/>
                                <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                           Opacity="0.75" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OcrSeparatorStyle" TargetType="Separator">
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Background" Value="{DynamicResource ThemeSeparatorBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Rectangle Height="1" Fill="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:CyberSnapTitleBar x:Name="OcrTitleBar" Grid.Row="0"
                                      Title="Text extraction (OCR)"
                                      ShowPinButton="True"
                                      CloseRequested="TitleBar_CloseRequested"
                                      PinRequested="TitleBar_PinRequested"/>

            <!-- OCR zone: section header (label + char count + copy) over the text box -->
            <Grid Grid.Row="1" Margin="14,2,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Recognized text" Style="{StaticResource OcrSectionHeaderText}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border x:Name="SearchBoxShell" Width="130" Height="24" CornerRadius="4"
                                Background="{DynamicResource ThemeInputBackgroundBrush}"
                                BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                Margin="0,0,6,0" Cursor="IBeam"
                                ToolTip="Search OCR text. Press Enter to cycle through matches; Shift+Enter goes back."
                                MouseLeftButtonDown="SearchBoxShell_MouseLeftButtonDown">
                            <Grid>
                                <TextBox x:Name="SearchTextBox" BorderThickness="0" Background="Transparent"
                                         Padding="6,0,22,0" VerticalContentAlignment="Center" FontSize="11"
                                         Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                         CaretBrush="{DynamicResource ThemeTextPrimaryBrush}"
                                         TextChanged="SearchTextBox_TextChanged"
                                         PreviewKeyDown="SearchTextBox_PreviewKeyDown">
                                    <TextBox.Template>
                                        <ControlTemplate TargetType="{x:Type TextBox}">
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Margin="{TemplateBinding Padding}"
                                                          Focusable="False"/>
                                        </ControlTemplate>
                                    </TextBox.Template>
                                </TextBox>
                                <TextBlock x:Name="SearchPlaceholder" Text="Search..."
                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0" IsHitTestVisible="False"
                                           Opacity="0.5"/>
                                <TextBlock x:Name="SearchClearBtn" Text="&#x2715;" FontSize="10"
                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                           HorizontalAlignment="Right" VerticalAlignment="Center"
                                           Width="20" TextAlignment="Center" Cursor="Hand"
                                           Visibility="Collapsed" ToolTip="Clear search"
                                           MouseLeftButtonDown="SearchClearBtn_MouseLeftButtonDown"/>
                            </Grid>
                        </Border>
                        <Button x:Name="PrevMatchBtn" Content="&#x25B2;"
                                Style="{StaticResource OcrSearchNavButton}" Visibility="Hidden"
                                Click="PrevMatchBtn_Click"/>
                        <Button x:Name="NextMatchBtn" Content="&#x25BC;"
                                Style="{StaticResource OcrSearchNavButton}" Visibility="Hidden"
                                Click="NextMatchBtn_Click"/>
                        <TextBlock x:Name="MatchCountText" VerticalAlignment="Center"
                                   Width="36" FontSize="10.5" Opacity="0.4"
                                   TextAlignment="Left"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   FontFamily="Segoe UI Variable Text" Margin="2,0,0,0"/>
                        <TextBlock x:Name="CharCountText" VerticalAlignment="Center"
                                   FontSize="10.5" Opacity="0.4"
                                   TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   FontFamily="Segoe UI Variable Text" Margin="10,0,0,0"/>
                        <Button x:Name="CopyBtn" Click="CopyBtn_Click"
                                Style="{StaticResource OcrHeaderActionButton}" Margin="10,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource CopyIconGeometry}"
                                      Stroke="{DynamicResource ThemeTextSecondaryBrush}" StrokeThickness="2.2"
                                      StrokeLineJoin="Round" Fill="Transparent"
                                      Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Copy and close" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border x:Name="OcrTextBoxBorder" Grid.Row="1" CornerRadius="8" Padding="2"
                        Background="{DynamicResource ThemeInputBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1">
                    <Grid ClipToBounds="True">
                        <Canvas x:Name="OcrSearchHighlightCanvas" IsHitTestVisible="False"/>
                        <TextBox x:Name="OcrTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="15"
                                 Padding="10,8"
                                 Background="Transparent" BorderThickness="0"
                                 Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                 CaretBrush="{DynamicResource ThemeTextPrimaryBrush}"
                                 Style="{StaticResource OcrTextBoxStyle}">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource OcrScrollBarStyle}"/>
                            </TextBox.Resources>
                        </TextBox>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="14,8,14,0">
                <StackPanel>
                    <!-- Divider separating the OCR zone from the translation zone -->
                    <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,0,0,8"/>

                    <!-- Collapse toggle: rotating chevron + localizable label (the chevron is a
                         separate Path so the text matches the "Translation" localization key). -->
                    <Button x:Name="ToggleTranslationBtn"
                            HorizontalAlignment="Left"
                            Padding="9,5" Margin="0,0,0,4"
                            Click="ToggleTranslationBtn_Click"
                            Style="{StaticResource ChromeButtonBase}"
                            Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                            Background="#08FFFFFF"
                            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                            BorderThickness="1"
                            Cursor="Hand" MinHeight="26">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path x:Name="TranslationChevron"
                                  Width="7" Height="9"
                                  Data="M 0 0 L 5 4.5 L 0 9 Z"
                                  Fill="{DynamicResource ThemeTextSecondaryBrush}"
                                  Stretch="Fill"
                                  VerticalAlignment="Center"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform x:Name="TranslationChevronRotation" Angle="0"/>
                                </Path.RenderTransform>
                            </Path>
                            <TextBlock Text="Translation"
                                       Margin="8,0,2,0"
                                       FontSize="11.5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                        </StackPanel>
                    </Button>

                    <!-- Translation controls (collapsed by default) -->
                    <StackPanel x:Name="TranslationPanel" Visibility="Collapsed">
                        <!-- Fixed-column grid: each control is anchored so the row never reflows
                             regardless of the selected language name length. -->
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="FromLanguageCombo" Grid.Column="0" Style="{StaticResource OcrComboStyle}"
                                      Margin="0,0,2,6"
                                      IsEditable="True" IsTextSearchEnabled="False"
                                      ItemContainerStyle="{StaticResource OcrComboItemStyle}"
                                      PreviewTextInput="FilterCombo_PreviewTextInput" PreviewKeyDown="FilterCombo_PreviewKeyDown"
                                      SelectionChanged="FromLanguageCombo_Changed"/>
                            <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="15" Margin="2,0,2,6" VerticalAlignment="Center" Opacity="0.35"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" FontWeight="Bold"/>
                            <ComboBox x:Name="ToLanguageCombo" Grid.Column="2" Style="{StaticResource OcrComboStyle}"
                                      Margin="0,0,2,6"
                                      IsEditable="True" IsTextSearchEnabled="False"
                                      ItemContainerStyle="{StaticResource OcrComboItemStyle}"
                                      PreviewTextInput="FilterCombo_PreviewTextInput" PreviewKeyDown="FilterCombo_PreviewKeyDown"
                                      SelectionChanged="ToLanguageCombo_Changed"/>
                            <Border Grid.Column="3" Width="1" Height="18" Background="{DynamicResource ThemeInputBorderBrush}" Margin="4,0,4,6"/>
                            <ComboBox x:Name="ModelCombo" Grid.Column="4" Style="{StaticResource OcrComboStyle}"
                                      Margin="0,0,4,6"
                                      ItemContainerStyle="{StaticResource OcrComboItemStyle}"
                                      SelectionChanged="ModelCombo_Changed">
                                <ComboBoxItem Content="MyMemory (free web)" Tag="3"/>
                                <ComboBoxItem Content="Google Translate" Tag="1"/>
                            </ComboBox>

                            <Button x:Name="TranslateBtn" Grid.Column="5" Content="Translate"
                                    HorizontalAlignment="Left"
                                    FontSize="12" Padding="14,6" Margin="0,0,0,6"
                                    Click="TranslateBtn_Click" Style="{StaticResource ChromeButtonBase}"
                                    Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                    Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                    Cursor="Hand" MinHeight="30" FontWeight="SemiBold"/>
                        </Grid>
                        <TextBlock x:Name="TranslationPreferenceStatusText"
                                   FontSize="11"
                                   Margin="2,4,0,0"
                                   Opacity="0.45"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Translation zone: section header (label + copy) over the translated text box -->
            <StackPanel x:Name="TranslatedSection" Grid.Row="3" Margin="14,8,14,0" Visibility="Collapsed">
                <Grid Margin="2,0,2,5">
                    <TextBlock Text="Translation" Style="{StaticResource OcrSectionHeaderText}"/>
                    <Button x:Name="CopyTranslationBtn" Click="CopyTranslationBtn_Click"
                            HorizontalAlignment="Right"
                            Style="{StaticResource OcrHeaderActionButton}" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource CopyIconGeometry}"
                                  Stroke="{DynamicResource ThemeTextSecondaryBrush}" StrokeThickness="2.2"
                                  StrokeLineJoin="Round" Fill="Transparent"
                                  Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center"/>
                            <TextBlock Text="Copy result" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Border x:Name="TranslatedOutputPanel"
                        CornerRadius="8" Padding="2"
                        Background="{DynamicResource TranslationTintBrush}"
                        BorderBrush="{DynamicResource TranslationTintBorderBrush}" BorderThickness="1"
                        MinHeight="70" MaxHeight="200">
                <Grid>
                    <TextBox x:Name="TranslatedTextBox" AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" IsReadOnly="True"
                             FontSize="15" FontFamily="Segoe UI"
                             Padding="10,8"
                             Background="Transparent" BorderThickness="0"
                             Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                             CaretBrush="{DynamicResource ThemeTextPrimaryBrush}"
                             Style="{StaticResource OcrTextBoxStyle}">
                        <TextBox.Resources>
                            <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource OcrScrollBarStyle}"/>
                        </TextBox.Resources>
                    </TextBox>
                    <Border x:Name="TranslationLoadingOverlay"
                            Background="#0DFFFFFF"
                            CornerRadius="6"
                            Margin="6"
                            Visibility="Collapsed"
                            ClipToBounds="True"
                            IsHitTestVisible="False">
                        <Grid>
                            <Rectangle x:Name="TranslationShimmerRect" Fill="{StaticResource TranslationShimmerBrush}" RadiusX="6" RadiusY="6"/>
                            <StackPanel Margin="12,8,12,8" VerticalAlignment="Center">
                                <Border Height="10" Width="150" CornerRadius="5" Background="#12FFFFFF" HorizontalAlignment="Left"/>
                                <Border Height="8" Margin="0,8,0,0" CornerRadius="4" Background="#0EFFFFFF"/>
                                <Border Height="8" Margin="0,6,42,0" CornerRadius="4" Background="#0EFFFFFF"/>
                                <ProgressBar x:Name="TranslateProgressBar"
                                             Height="3"
                                             Margin="0,10,0,0"
                                             IsIndeterminate="True"
                                             Opacity="0.9"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TranslateStatus" FontSize="11"
                               Opacity="0.25" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                               Margin="16,0"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                               IsHitTestVisible="False" Visibility="Collapsed"/>
                </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
