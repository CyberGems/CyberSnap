                                                            PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                            Services:LocalizationService.SourceToolTip="Move the save notification button"
                                                            AutomationProperties.Name="Save notification button"                                                            Tag="Save">
