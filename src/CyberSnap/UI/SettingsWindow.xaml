                                                  ToolTip="Keep gallery for 7 days"
                                                  AutomationProperties.Name="Keep gallery for 7 days"
                                                  AutomationProperties.HelpText="Automatically remove capture gallery older than 7 days."/>
                                    <ComboBoxItem Content="30 days"
                                                  ToolTip="Keep gallery for 30 days"
                                                  AutomationProperties.Name="Keep gallery for 30 days"
                                                  AutomationProperties.HelpText="Automatically remove capture gallery older than 30 days."/>
