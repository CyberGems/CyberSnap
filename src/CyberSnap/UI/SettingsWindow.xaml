                                                           <Image x:Name="ToastLayoutAiRedirectIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                                                                  RenderOptions.BitmapScalingMode="HighQuality"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                       </Border>
                                                       <Border x:Name="ToastLayoutEditBtn"
                                                               Width="30" Height="30" CornerRadius="9"
                                                               Background="#FF303030" BorderBrush="{DynamicResource ThemeWindowBorderBrush}" BorderThickness="1"
                                                               Cursor="Hand"
                                                               PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                               Services:LocalizationService.SourceToolTip="Move the edit notification button"
                                                               AutomationProperties.Name="Edit notification button"                                                               Tag="Edit">
                                                           <Image x:Name="ToastLayoutEditIcon" Width="14" Height="14" Stretch="Uniform" Opacity="0.9"
                                                                  RenderOptions.BitmapScalingMode="HighQuality"
                                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                       </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="14,10,14,8" Visibility="Collapsed">
