                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- App Theme — refined side-by-side row (icon + copy | ThemeCards).
                                 CardWidth/margins start at the design baseline; UpdateThemeCardLayoutForScale()
                                 fits them into the real content width under LayoutTransform. -->
                            <Grid x:Name="ThemeSettingRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE793;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel x:Name="ThemeSettingTextHost" Grid.Column="1" VerticalAlignment="Center"
                                            MaxWidth="280" HorizontalAlignment="Left" Margin="0,0,12,0">
                                    <TextBlock Text="App theme" Style="{StaticResource SettingTitle}" Services:LocalizationService.SourceText="App theme"/>
