                                         <Border x:Name="PosBlock_TopLeft" Grid.Row="0" Grid.Column="0" Margin="2" Style="{StaticResource PositionBlockStyle}" Cursor="Hand" MouseLeftButtonDown="ToastPositionBlock_Click" Services:LocalizationService.SourceToolTip="Top Left" Tag="TopLeft">
