                                <!-- Icon-only reset — same ↺ glyph as per-row restore; larger for the master control. -->
                                <Button x:Name="ResetAllSoundsBtn"
                                        Style="{StaticResource SettingsIconResetButton}"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        ToolTip="Revert all sounds to their built-in defaults."
                                        Services:LocalizationService.SourceToolTip="Revert all sounds to their built-in defaults."
                                        AutomationProperties.Name="Reset all sounds to defaults"
                                        Click="ResetAllSoundsBtn_Click"/>
