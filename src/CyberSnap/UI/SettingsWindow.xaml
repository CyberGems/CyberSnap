                        <Grid Style="{StaticResource SettingRow}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource SettingIconFrame}">
                                <TextBlock Text="&#xE767;" Style="{StaticResource SettingIconGlyph}"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="Enable sound effects" Services:LocalizationService.SourceText="Enable sound effects" Style="{StaticResource SettingTitle}"/>
                                <TextBlock Text="Master switch for all capture and notification sounds. Customize individual events below using MP3 or WAV files." Services:LocalizationService.SourceText="Master switch for all capture and notification sounds. Customize individual events below using MP3 or WAV files." Style="{StaticResource SettingDescription}" TextWrapping="Wrap"/>
                            </StackPanel>
