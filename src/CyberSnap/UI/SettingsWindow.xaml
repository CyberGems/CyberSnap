                                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Visibility="Collapsed"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Grid.Row="2" Margin="12,0,12,12" CornerRadius="2" Background="#65FFFFFF"/>
                                        </Grid>
                                    </Border>

                                    </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
