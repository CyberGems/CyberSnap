                <StackPanel>
                    <TextBlock Text="Interface" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Interface Language -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xF2B7;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Interface language" Style="{StaticResource SettingTitle}" Services:LocalizationService.SourceText="Interface language"/>
                                    <TextBlock Text="Choose your preferred language for CyberSnap." Style="{StaticResource SettingDescription}" Services:LocalizationService.SourceText="Choose your preferred language for CyberSnap."/>
                                </StackPanel>
                                <ComboBox x:Name="InterfaceLanguageCombo" Grid.Column="2" MinWidth="145"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
