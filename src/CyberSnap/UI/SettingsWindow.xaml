                                          ToolTip="Language to translate into by default."
                                          Services:LocalizationService.SourceToolTip="Language to translate into by default."
                                          IsEditable="False" IsTextSearchEnabled="True"
                                          SelectionChanged="TranslateToCombo_Changed"/>
                            </Grid>

                        </Grid>
                    </Border>
                    <TextBlock x:Name="TranslationPreferenceStatusText"
                               Style="{StaticResource SettingsStatusText}"
                               Visibility="Collapsed"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.Name="Translation preference status"
                               AutomationProperties.LiveSetting="Polite"
                               Margin="4,8,0,0"/>

                </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Toolbar -->
            <!-- Toolbar panel removed — merged into Hotkeys panel above -->

            <!-- About panel placeholder - content is below -->

            <!-- Search Results Panel -->
            <ScrollViewer x:Name="SearchResultsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,56,18,18">
                <StackPanel x:Name="SearchResultsStack">
