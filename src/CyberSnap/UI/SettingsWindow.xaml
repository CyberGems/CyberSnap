                                             <Border x:Name="PosDot_BottomRight" Width="9" Height="9" CornerRadius="2" Background="#40808080" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="3"/>
                                         </Border>
                                     </Grid>
                                 </Border>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
