                                    <TextBlock Text="&#xE7F4;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Span selection overlay across all monitors" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Use one overlay over the full virtual desktop." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="OverlayAllMonitorsCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          ToolTip="Use one overlay across the full virtual desktop"
                                          AutomationProperties.Name="Span selection overlay across all monitors"
                                          Checked="OverlayAllMonitorsCheck_Changed" Unchecked="OverlayAllMonitorsCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE793;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Annotation shadow" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Adds a soft drop shadow to annotations for depth." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="AnnotationStrokeShadowCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          ToolTip="Adds a soft drop shadow to annotations for depth"
                                          AutomationProperties.Name="Annotation shadow"
                                          Checked="AnnotationStrokeShadowCheck_Changed" Unchecked="AnnotationStrokeShadowCheck_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>


                    <StackPanel x:Name="CaptureConfirmPillsSection">
                    <TextBlock Services:LocalizationService.SourceText="Confirm destination buttons" Style="{StaticResource SectionLabel}" Margin="4,16,0,9"/>
                    <Border Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Single glossary (not repeated under Visibility). -->
                            <StackPanel Grid.Row="0">
                                <Border CornerRadius="8" Padding="12,9" BorderThickness="1"
                                        Background="{DynamicResource ThemeTabHoverBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Margin="0,1,10,0" VerticalAlignment="Top"
                                                   Foreground="{DynamicResource ThemeAccentBrush}"/>
                                        <TextBlock Services:LocalizationService.SourceText="Choose which actions appear after you select a region. Choosing a destination confirms the capture (the first destination button on the right is the default action triggered by Enter or double-click). Retry and Cancel stay available."
                                                   FontSize="12.5" TextWrapping="Wrap"
                                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock x:Name="ToastLayoutSelectionText" Text="" Style="{StaticResource InfoText}"
                                           Visibility="Collapsed" Margin="0,4,0,0"
                                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                           AutomationProperties.Name="notification layout selection"
                                           AutomationProperties.HelpText="{Binding Text, RelativeSource={RelativeSource Self}}"
                                           AutomationProperties.LiveSetting="Polite"/>
                            </StackPanel>

                            <Border Grid.Row="1" Margin="0,10,0,0"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource ThemeInputBackgroundBrush}"
                                    Padding="14,16,14,16"
                                    ClipToBounds="False">
                                <Grid x:Name="ToastDesignerRoot" HorizontalAlignment="Stretch" Background="Transparent"
                                      AllowDrop="True" DragOver="ToastDesigner_DragOver"
                                      ClipToBounds="False">
                                    
                                    <!-- Single-column confirm-destination designer (no system-toast mock column). -->
<Border x:Name="EditorButtonsCard"
                                            CornerRadius="12" Padding="14,14,14,14" BorderThickness="1"
                                            Background="{DynamicResource ThemeCardBrush}"
                                            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                            VerticalAlignment="Stretch" Cursor="Arrow"
                                            SnapsToDevicePixels="True" UseLayoutRounding="True"
                                            ClipToBounds="False"
                                            >
                                        <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0" Margin="0,0,0,4">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                                       Margin="0,1,8,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThemeAccentBrush}"/>
                                            <TextBlock Services:LocalizationService.SourceText="Confirm destination buttons"
                                                       FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       TextWrapping="Wrap" MaxWidth="220"
                                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                            <Border CornerRadius="4" Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Background="{DynamicResource ThemeTabActiveBrush}"
                                                    BorderBrush="{DynamicResource ThemeAccentBrush}" BorderThickness="1">
                                                <TextBlock Services:LocalizationService.SourceText="Customizable"
                                                           FontSize="10.5" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource ThemeAccentBrush}"/>
                                            </Border>

                                            <Button x:Name="ResetToastButtonsBtn" Content="↺"
                                                    Margin="8,0,0,0"
                                                    Width="28" Height="28" MinWidth="28" MinHeight="28" Padding="0"
                                                    VerticalAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    FontSize="13" FontWeight="Bold" Cursor="Hand"
                                                    AutomationProperties.Name="Default destination button layout"
                                                    Services:LocalizationService.SourceToolTip="Restore the default destination button layout."
                                                    Click="ResetToastButtonsBtn_Click"/>
                                        </StackPanel>
                                        <Grid Margin="0,2,0,14" MinHeight="40">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Services:LocalizationService.SourceText="Show labels on destination buttons"
                                                           FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                                <TextBlock Services:LocalizationService.SourceText="Short text beside each destination icon. Cancel and Retry stay icon-only."
                                                           FontSize="11" TextWrapping="Wrap" Opacity="0.72" Margin="0,3,0,0"
                                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ConfirmPillShowLabelsCheck"
                                                      Grid.Column="1"
                                                      Content=""
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Right"
                                                      Margin="0,2,0,2"
                                                      Checked="ConfirmPillShowLabelsCheck_Changed"
                                                      Unchecked="ConfirmPillShowLabelsCheck_Changed"/>
                                        </Grid>

                                        <!-- Legacy ImagePreview toast click action — kept for settings persistence / search; hidden from the confirm-pill designer. -->
                                        <Grid Margin="0,0,0,10" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Services:LocalizationService.SourceText="On capture preview click:"
                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                            <ComboBox x:Name="ToastPreviewClickActionCombo" Grid.Column="1" MinWidth="190"
                                                      VerticalAlignment="Center"
                                                      AutomationProperties.Name="On capture preview click"
                                                      Services:LocalizationService.SourceToolTip="Choose what happens when you click the capture preview on a notification."
                                                      SelectionChanged="ToastPreviewClickActionCombo_SelectionChanged">
                                                <ComboBoxItem Content="Open in editor"
                                                              Services:LocalizationService.SourceToolTip="Open the capture in the built-in editor."
                                                              AutomationProperties.Name="Open in editor"/>
                                                <ComboBoxItem Content="Open in default viewer"
                                                              Services:LocalizationService.SourceToolTip="Open the file with the system default image viewer."
                                                              AutomationProperties.Name="Open in default viewer"/>
                                                <ComboBoxItem Content="Copy to clipboard"
                                                              Services:LocalizationService.SourceToolTip="Copy the capture to your clipboard."
                                                              AutomationProperties.Name="Copy to clipboard"/>
                                                <ComboBoxItem Content="Save"
                                                              Services:LocalizationService.SourceToolTip="Save the capture to a file."
                                                              AutomationProperties.Name="Save"/>
                                                <ComboBoxItem Content="Open in Gallery"
                                                              Services:LocalizationService.SourceToolTip="Open the capture in the Gallery."
                                                              AutomationProperties.Name="Open in Gallery"/>
                                                <ComboBoxItem Content="Close immediately"
                                                              Services:LocalizationService.SourceToolTip="Dismiss the notification instantly without a fade-out."
                                                              AutomationProperties.Name="Close immediately"/>
                                            </ComboBox>
                                        </Grid>
                                        </StackPanel>

                                    <!-- Capture mock + palette sit on the bottom edge so they line up with system mocks. -->
                                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                                    <TextBlock x:Name="CaptureDesignIdleNote" Margin="0,0,0,10" FontSize="11.5"
                                               TextWrapping="Wrap" Opacity="0.9"
                                               Visibility="Collapsed"
                                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                               Services:LocalizationService.SourceText="Layout used for confirm-mode destination pills after you select a region (the first button in the list is the default action triggered by Enter or double-click)."/>
                                    <StackPanel HorizontalAlignment="Stretch">
                                    <StackPanel x:Name="ToastLayoutStack" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                                    <!-- Region confirm mock: selection silhouette + Cancel/Retry chrome + destination slots. -->
                                    <Border x:Name="ToastLayoutShell" Height="200" CornerRadius="12"
                                            BorderThickness="1" HorizontalAlignment="Stretch"
                                            MaxWidth="420">
                                        <Grid x:Name="ToastLayoutPreviewSurface" AllowDrop="True" PreviewMouseMove="ToastPreviewSurface_PreviewMouseMove"
                                              ClipToBounds="True">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Selected-region silhouette (not a toast preview). -->
                                            <Border x:Name="ToastLayoutImageArea" Grid.Row="0" Margin="18,16,18,10"
                                                    CornerRadius="8" BorderThickness="1.5"
                                                    Services:LocalizationService.SourceToolTip="Selected region preview">
                                                <Grid>
                                                    <TextBlock x:Name="ToastLayoutImageGlyph"
                                                               Text="&#xEB9F;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                                               Foreground="White" Opacity="0.15"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               IsHitTestVisible="False"/>
                                                    <Border x:Name="ToastLayoutVideoBadge"
                                                            Width="40" Height="40" CornerRadius="20"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                            IsHitTestVisible="False" Visibility="Collapsed"
                                                            Background="#B4000000"
                                                            AutomationProperties.Name="Video or GIF capture preview">
                                                        <Path Data="M8,5 L8,19 L19,12 Z"
                                                              Fill="White" Stretch="Uniform"
                                                              Width="15" Height="15"
                                                              Margin="2,0,0,0"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Confirm chrome strip at bottom of shell: hint (when shown) sits above buttons;
                                                 row * image reflows so the button strip stays pinned to the bottom. -->
                                            <StackPanel Grid.Row="1" Margin="12,0,12,14">
                                                <TextBlock x:Name="ConfirmBarInlineHint"
                                                           Margin="0,0,0,6"
                                                           FontSize="11.5" FontWeight="SemiBold"
                                                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                                           Foreground="#FFEF4444"
                                                           TextAlignment="Center"
                                                           Visibility="Collapsed"
                                                           IsHitTestVisible="False"/>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                            HorizontalAlignment="Left">
                                                    <Border x:Name="ConfirmMockCancelPill" Width="34" Height="34" CornerRadius="14" Margin="0,0,10,0"
                                                            Cursor="No" Opacity="0.85"
                                                            Background="{DynamicResource ThemeInputBackgroundBrush}"
                                                            BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                                            PreviewMouseLeftButtonDown="ConfirmFixedPill_PreviewMouseLeftButtonDown"
                                                            PreviewMouseMove="ConfirmFixedPill_PreviewMouseMove"
                                                            PreviewMouseLeftButtonUp="ConfirmFixedPill_PreviewMouseLeftButtonUp"
                                                            AutomationProperties.Name="Cancel (fixed)">
                                                        <TextBlock x:Name="ConfirmMockCancelGlyph" Text="&#xF3B1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                                   RenderTransformOrigin="0.5,0.5"
                                                                   IsHitTestVisible="False">
                                                             <TextBlock.RenderTransform>
                                                                 <ScaleTransform ScaleX="-1"/>
                                                             </TextBlock.RenderTransform>
                                                        </TextBlock>
                                                    </Border>
                                                    <Border x:Name="ConfirmMockRetryPill" Width="34" Height="34" CornerRadius="14" Margin="0,0,12,0"
                                                            Cursor="No" Opacity="0.85"
                                                            Background="{DynamicResource ThemeInputBackgroundBrush}"
                                                            BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1"
                                                            PreviewMouseLeftButtonDown="ConfirmFixedPill_PreviewMouseLeftButtonDown"
                                                            PreviewMouseMove="ConfirmFixedPill_PreviewMouseMove"
                                                            PreviewMouseLeftButtonUp="ConfirmFixedPill_PreviewMouseLeftButtonUp"
                                                            AutomationProperties.Name="Retry (fixed)">
                                                        <TextBlock x:Name="ConfirmMockRetryGlyph" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                                   IsHitTestVisible="False"/>
                                                    </Border>
                                                    <Border Width="1" Height="22" Margin="0,0,12,0" Opacity="0.28"
                                                            Background="{DynamicResource ThemeTextPrimaryBrush}"
                                                            VerticalAlignment="Center"/>

                                                    <!-- Five destination slots in a single row (Full = Save/Copy/Edit/Share/Gallery). -->
                                                    <Grid x:Name="ToastLayoutActionsPanel" Height="36" MinWidth="200"
                                                          VerticalAlignment="Center">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="36"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Slot placeholders — always visible when empty; invisible but hit-testable when occupied -->
                                                <Border x:Name="ToastLayoutSlotTopLeft" Grid.Column="0"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="0"
                                                        AllowDrop="True" Tag="TopLeft"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                        BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                        Opacity="0.22"
                                                        Background="Transparent"/>
                                                <Border x:Name="ToastLayoutSlotTopInnerLeft" Grid.Column="1"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="0"
                                                        AllowDrop="True" Tag="TopInnerLeft"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                        BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                        Opacity="0.22"
                                                        Background="Transparent"/>
                                                <Border x:Name="ToastLayoutSlotTopInnerRight" Grid.Column="2"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="0"
                                                        AllowDrop="True" Tag="TopInnerRight"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                        BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                        Opacity="0.22"
                                                        Background="Transparent"/>
                                                <Border x:Name="ToastLayoutSlotTopRight" Grid.Column="3"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="0"
                                                        AllowDrop="True" Tag="TopRight"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                        BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                        Opacity="0.22"
                                                        Background="Transparent"/>
                                                <Border x:Name="ToastLayoutSlotBottomLeft" Grid.Column="4"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                                        Margin="0"
                                                        AllowDrop="True" Tag="BottomLeft"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                        BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                        Opacity="0.22"
                                                        Background="Transparent"/>
                                                <!-- Legacy slots (not shown) — kept for Tag drop resolution if old layouts reference them -->
                                                <Border x:Name="ToastLayoutSlotBottomInnerLeft" Visibility="Collapsed"
                                                        AllowDrop="True" Tag="BottomInnerLeft"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"/>
                                                <Border x:Name="ToastLayoutSlotBottomInnerRight" Visibility="Collapsed"
                                                        AllowDrop="True" Tag="BottomInnerRight"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"/>
                                                <Border x:Name="ToastLayoutSlotBottomRight" Visibility="Collapsed"
                                                        AllowDrop="True" Tag="BottomRight"
                                                        DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"/>

                                                <Border x:Name="ToastLayoutCloseBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                        Services:LocalizationService.SourceToolTip="Move the Cancel-related control"
                                                        AutomationProperties.Name="Close notification button" Tag="Close">
                                                    <Image x:Name="ToastLayoutCloseIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutPinBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                        Services:LocalizationService.SourceToolTip="Not used in confirm mode."
                                                        AutomationProperties.Name="Pin notification button" Tag="Pin">
                                                    <Image x:Name="ToastLayoutPinIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutSaveBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"

                                                        AutomationProperties.Name="Save destination pill" Tag="Save">
                                                    <Image x:Name="ToastLayoutSaveIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutCopyBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"

                                                        AutomationProperties.Name="Copy destination pill" Tag="Copy">
                                                    <Image x:Name="ToastLayoutCopyIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutShareBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"

                                                        AutomationProperties.Name="Share destination pill" Tag="Share">
                                                    <Image x:Name="ToastLayoutShareIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutDeleteBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                        Services:LocalizationService.SourceToolTip="Not used in confirm mode."
                                                        AutomationProperties.Name="Delete notification button" Tag="Delete">
                                                    <Image x:Name="ToastLayoutDeleteIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutAiRedirectBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"
                                                        Services:LocalizationService.SourceToolTip="Not used in confirm mode."
                                                        AutomationProperties.Name="Gallery notification button" Tag="History">
                                                    <Image x:Name="ToastLayoutAiRedirectIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border x:Name="ToastLayoutEditBtn"
                                                        Width="34" Height="34" CornerRadius="14"
                                                        Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeAccentSubtleBrush}" BorderThickness="1"
                                                        Cursor="Hand"
                                                        PreviewMouseLeftButtonDown="ToastPreviewButton_PreviewMouseLeftButtonDown"

                                                        AutomationProperties.Name="Edit destination pill" Tag="Edit">
                                                    <Image x:Name="ToastLayoutEditIcon" Width="16" Height="16" Stretch="Uniform" Opacity="0.9"
                                                           RenderOptions.BitmapScalingMode="HighQuality"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                    </Grid>
                                                </StackPanel>
                                                <TextBlock Margin="0,8,0,0" FontSize="11" Opacity="0.65"
                                                           TextWrapping="Wrap"
                                                           Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                           Services:LocalizationService.SourceText="Cancel and Retry stay fixed. Use × on a button to remove it; use + in the tray to add it back."/>
                                            </StackPanel>

                                            <!-- Legacy toast rail kept for code references; unused in confirm-bar mock. -->
                                            <Border x:Name="ToastLayoutRail" Visibility="Collapsed" HorizontalAlignment="Stretch">
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="ToastLayoutRailGlow" Color="#FF7A00FF" BlurRadius="4" ShadowDepth="0" Opacity="0.45"/>
                                                </Border.Effect>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    </StackPanel>

                                    <!-- Hidden destinations tray: chips with + to restore (centered drawer). -->
                                    <Border Margin="0,14,0,0" Padding="12,10" CornerRadius="12"
                                            BorderThickness="1"
                                            Background="{DynamicResource ThemeTabHoverBrush}"
                                            BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock Services:LocalizationService.SourceText="Available destinations"
                                                       FontSize="11.5" FontWeight="SemiBold" Opacity="0.85"
                                                       HorizontalAlignment="Center" Margin="0,0,0,8"
                                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                            <StackPanel x:Name="ToastButtonRows" Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        MinHeight="40"/>
                                            <TextBlock x:Name="ToastTrayEmptyHint" Margin="0,2,0,0" FontSize="11" Opacity="0.55"
                                                       HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"
                                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                                       Visibility="Collapsed"
                                                       Services:LocalizationService.SourceText="All destinations are on the bar. Remove one with × to store it here."/>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>
                                    </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Floating drag ghost over the designer surface. -->
                                    <Image x:Name="ToastDragGhost" Width="30" Height="30"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           IsHitTestVisible="False" Visibility="Collapsed" Opacity="0.9"
                                           RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Effect>
                                            <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
                                        </Image.Effect>
                                    </Image>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
