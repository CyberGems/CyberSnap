                                                            Opacity="0.22"
                                                            Background="Transparent"/>
                                                    <Border x:Name="ToastLayoutSlotBottomLeft"
                                                            Width="28" Height="28" CornerRadius="7"
                                                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                            Margin="8,0,0,8"
