                                          ToolTip="Master switch for every capture and notification sound. Turn off to silence them all."
                                          Checked="MuteSoundsCheck_Changed" Unchecked="MuteSoundsCheck_Changed"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <StackPanel x:Name="SoundCustomizationPanel"/>
                    <TextBlock x:Name="SoundsPreferenceStatusText"
                               Style="{StaticResource SettingsStatusText}"
                               Visibility="Collapsed"
                               Margin="4,8,0,0"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="WidgetPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,56,18,18">
                <StackPanel>
                    <TextBlock Text="Floating Widget" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Show Widget CheckBox -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE700;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Show edge capture widget" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Keep the capture widget peeking from the screen edge for hover or click activation." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="ShowCaptureWidgetCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Show edge capture widget"
                                          ToolTip="Enable the edge-peeking capture widget."
                                          Checked="ShowCaptureWidgetCheck_Changed" Unchecked="ShowCaptureWidgetCheck_Changed"/>
                            </Grid>
                            <Border x:Name="WidgetOptionsSeparator" Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>

                            <!-- Widget Always On Top CheckBox -->
                            <Grid x:Name="WidgetAlwaysOnTopRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE718;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Always on top" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Keep the floating widget above all other windows." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="WidgetAlwaysOnTopCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Always on top"
                                          ToolTip="Keep the floating widget above all other windows."
                                          Checked="WidgetAlwaysOnTopCheck_Changed" Unchecked="WidgetAlwaysOnTopCheck_Changed"/>
                            </Grid>
                            <Border x:Name="WidgetAlwaysOnTopSeparator" Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>

                            <!-- Capture cursor (mirrors the widget toggle) -->
                            <Grid x:Name="WidgetCaptureCursorRow" Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE962;" Style="{StaticResource SettingIconGlyph}"/>
