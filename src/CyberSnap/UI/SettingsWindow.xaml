            <Setter Property="Height" Value="24"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ProviderIconImage" TargetType="Image">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
        </Style>

        <Style TargetType="{x:Type controls:ProviderSection}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ProviderSection}">
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel x:Name="ProviderHeaderRow" Margin="0,0,0,12" LastChildFill="True">
                                    <ContentControl x:Name="HeaderExtrasHost"
                                                    DockPanel.Dock="Right"
                                                    Content="{TemplateBinding HeaderExtras}"
                                                    VerticalAlignment="Center"/>
                                    <Border x:Name="ProviderHeaderIconFrame" Style="{StaticResource SettingIconFrame}">
                                        <Image x:Name="ProviderHeaderIcon"
                                               Source="{TemplateBinding IconSource}"
                                               Width="16"
                                               Height="16"
                                               Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontSize="12.5"
                                               FontWeight="SemiBold"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <ContentPresenter Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Header" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderRow" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IconSource" Value="{x:Null}">
                                <Setter TargetName="ProviderHeaderIconFrame" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HeaderExtras" Value="{x:Null}">
                                <Setter TargetName="HeaderExtrasHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed scrollbar (same as History window) -->
        <Style x:Key="SettingsScrollThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Opacity" Value="0.35"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border CornerRadius="3" Background="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,2,8,2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsScrollBarStyle" TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Opacity" Value="0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent" Width="{TemplateBinding Width}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True" Margin="0,6,0,6">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Background="Transparent" BorderThickness="0" Focusable="False" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource SettingsScrollThumbStyle}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Background="Transparent" BorderThickness="0" Focusable="False" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Apply themed scrollbar to all ScrollBars in this window -->
        <Style TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource SettingsScrollBarStyle}"/>

    </Window.Resources>

        <Border Margin="1" CornerRadius="10">
