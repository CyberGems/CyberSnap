                                </StackPanel>
                                <StackPanel x:Name="ThemeCardsHost" Grid.Column="2" Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <controls:ThemeCard x:Name="ThemeDarkRadio" Caption="CyberSnap"
                                                 ThemeMode="Dark" CardWidth="104" GroupName="AppTheme" Margin="0,0,14,0"
                                                 IsDefaultTheme="True"
                                                 AutomationProperties.Name="CyberSnap theme"
                                                 ToolTip="Always use the signature CyberSnap theme."
                                                 Checked="AppThemeRadio_Changed"/>
                                    <controls:ThemeCard x:Name="ThemeGrayscaleRadio" Caption="Dark"
                                                 ThemeMode="Grayscale" CardWidth="104" GroupName="AppTheme" Margin="0,0,14,0"
                                                 AutomationProperties.Name="Dark theme"
                                                 ToolTip="Sober, monochrome dark theme."
                                                 Checked="AppThemeRadio_Changed"/>
                                    <controls:ThemeCard x:Name="ThemeLightRadio" Caption="Light"
                                                 ThemeMode="Light" CardWidth="104" GroupName="AppTheme" Margin="0,0,14,0"
                                                 AutomationProperties.Name="Light theme"
                                                 ToolTip="Always use the light theme."
                                                 Checked="AppThemeRadio_Changed"/>
                                    <controls:ThemeCard x:Name="ThemeSystemRadio" Caption="System"
                                                 ThemeMode="System" CardWidth="104" GroupName="AppTheme"
                                                 AutomationProperties.Name="System theme"
                                                 ToolTip="Follows Windows: CyberSnap when dark, Light when light."
                                                 Checked="AppThemeRadio_Changed"/>
                                </StackPanel>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- UI Scale — Width mirrors language combo so right edges stay aligned. -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE71E;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="User Interface Scale" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Increase the default size of windows, capture interface, widget and notifications." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <ComboBox x:Name="UiScaleCombo" Grid.Column="2"
                                          MinWidth="145"
                                          Width="{Binding ActualWidth, ElementName=InterfaceLanguageCombo, FallbackValue=145}"
