                                           SelectionChanged="DefaultCaptureModeCombo_SelectionChanged">
                                     <ComboBoxItem Content="Area select"
                                                   ToolTip="Drag from corner to corner."
                                                   AutomationProperties.Name="Area Capture"
                                                   AutomationProperties.HelpText="Start captures with the standard area capture tool."/>
                                     <ComboBoxItem Content="From center"
