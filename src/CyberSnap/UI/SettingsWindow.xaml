                                                            DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                            BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                            Opacity="0.22"
                                                            Background="Transparent"/>
                                                    <Border x:Name="ToastLayoutSlotBottomInnerLeft"
                                                            Width="28" Height="28" CornerRadius="7"
                                                            HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                            Margin="48,0,0,8"
                                                            AllowDrop="True" Tag="BottomInnerLeft"
                                                            DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                            BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                            Opacity="0.22"
                                                            Background="Transparent"/>
                                                    <Border x:Name="ToastLayoutSlotBottomRight"
                                                            Width="28" Height="28" CornerRadius="7"
                                                            HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                            Margin="0,0,8,8"
                                                            AllowDrop="True" Tag="BottomRight"
                                                            DragEnter="ToastSlot_DragEnter" DragLeave="ToastSlot_DragLeave" Drop="ToastSlot_Drop"
                                                            BorderBrush="{DynamicResource ThemeTextPrimaryBrush}" BorderThickness="1"
                                                            Opacity="0.22"
                                                            Background="Transparent"/>
