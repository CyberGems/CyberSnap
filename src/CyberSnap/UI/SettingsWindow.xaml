<Window x:Class="CyberSnap.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:Services="clr-namespace:CyberSnap.Services"
        Title="Configuration"
        Height="680" Width="960"
        MinHeight="560" MinWidth="860"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Icon="pack://application:,,,/Assets/Icons/Configuration.ico">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeTabActiveBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#0EFFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemePanelBackgroundBrush" Color="#FF0D0F17"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>
        <sys:Double x:Key="SettingsControlHeight">30</sys:Double>
        <Thickness x:Key="SettingsControlPadding">10,5</Thickness>
        <sys:Double x:Key="SettingsControlFontSize">12</sys:Double>
        <sys:Double x:Key="SettingsControlMinWidth">88</sys:Double>

        <Style TargetType="ScrollViewer">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Focusable" Value="False"/>
        </Style>

        <Style x:Key="TabPill" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="12,5" CornerRadius="6" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="10,4" CornerRadius="5" Cursor="Hand" Background="Transparent">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="11"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.5"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.92"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="Medium"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tb" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Larger chip-style sub-tabs for Settings → Uploads -->
        <Style x:Key="UploadSubTab" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Padding="14,7" CornerRadius="7" Cursor="Hand"
                                Background="Transparent" BorderThickness="1" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="Tb" Text="{TemplateBinding Content}" FontSize="12.5"
                                       FontFamily="Segoe UI Variable Text"
                                       Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.55"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabActiveBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="1"/>
                                <Setter TargetName="Tb" Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Tb" Property="Foreground" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter TargetName="Tb" Property="Opacity" Value="0.82"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Margin" Value="0,4,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        </Style>

        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Bd" Padding="9,0" Height="34" CornerRadius="4" Cursor="Hand" Background="Transparent"
                                    Margin="0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="Icon" Grid.Column="0" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14" Text="&#xE713;" Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                               Opacity="0.74" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <Path x:Name="VectorIcon" Grid.Column="0" Width="14" Height="14" 
                                           Stretch="Uniform" Fill="{DynamicResource ThemeTextPrimaryBrush}"
                                           Stroke="{DynamicResource ThemeTextPrimaryBrush}" StrokeThickness="0.3"
                                           Opacity="0.74" HorizontalAlignment="Left" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                                    <TextBlock x:Name="Tb" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="12"
                                               FontFamily="Segoe UI Variable Text"
                                               Foreground="{DynamicResource ThemeTextPrimaryBrush}" Opacity="0.82"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border x:Name="ActiveIndicator" Width="3" Height="16" CornerRadius="1.5"
                                    Background="{DynamicResource ThemeAccentBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,0,0"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00FFFF" BlurRadius="6" ShadowDepth="0" Opacity="0.8"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="General">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE713;"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Sounds">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE767;"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Capture">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VectorIcon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="VectorIcon" Property="Data" Value="M4.5 3C3.67 3 3 3.67 3 4.5v2a.5.5 0 0 1-1 0v-2A2.5 2.5 0 0 1 4.5 2h2a.5.5 0 0 1 0 1h-2Zm0 14A1.5 1.5 0 0 1 3 15.5v-2a.5.5 0 0 0-1 0v2A2.5 2.5 0 0 0 4.5 18h2a.5.5 0 0 0 0-1h-2ZM17 4.5c0-.83-.67-1.5-1.5-1.5h-2a.5.5 0 0 1 0-1h2A2.5 2.5 0 0 1 18 4.5v2a.5.5 0 0 1-1 0v-2ZM15.5 17c.83 0 1.5-.67 1.5-1.5v-2a.5.5 0 0 1 1 0v2a2.5 2.5 0 0 1-2.5 2.5h-2a.5.5 0 0 1 0-1h2ZM10 8.25a1.75 1.75 0 1 1 0 3.5 1.75 1.75 0 0 1 0-3.5Z"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Notifications">
                                <Setter TargetName="Icon" Property="Text" Value="&#xEA8F;"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Widget">
                                <Setter TargetName="Icon" Property="Text" Value="&#xE700;"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Editor">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VectorIcon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="VectorIcon" Property="Data" Value="M10.5 4.00003C10.7761 4.00003 11 4.22389 11 4.50003C10.9999 4.77614 10.7761 5.00003 10.5 5.00003H6C4.89543 5.00003 4 5.89546 4 7.00002V14C4.00004 15.1045 4.89545 16 6 16H13C14.1045 16 14.9999 15.1045 15 14V9.50002C15 9.22388 15.2238 9.00002 15.5 9.00002C15.7761 9.00002 16 9.22388 16 9.50002V14C15.9999 15.6568 14.6568 17 13 17H6C4.34317 17 3.00004 15.6568 3 14V7.00002C3 5.34318 4.34314 4.00003 6 4.00003H10.5ZM16.1465 3.14652C16.3417 2.95126 16.6582 2.95126 16.8535 3.14652C17.0487 3.34179 17.0487 3.65832 16.8535 3.85355L9.06054 11.6455L7.99999 12L8.35351 10.9395L16.1465 3.14652Z"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Tools">
                                <Setter TargetName="Icon" Property="Text" Value="&#xEE6F;"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Video">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VectorIcon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="VectorIcon" Property="Data" Value="M5 4C3.34315 4 2 5.34315 2 7V13C2 14.6569 3.34315 16 5 16H10C11.6569 16 13 14.6569 13 13V12.6787L16.0372 14.7759C16.8664 15.3484 17.9975 14.7549 17.9975 13.7473V6.25215C17.9975 5.24453 16.8664 4.65101 16.0372 5.22353L13 7.32067V7C13 5.34315 11.6569 4 10 4H5ZM13 8.53588L16.6054 6.04643C16.7712 5.93193 16.9975 6.05063 16.9975 6.25215V13.7473C16.9975 13.9488 16.7712 14.0675 16.6054 13.953L13 11.4635V8.53588ZM3 7C3 5.89543 3.89543 5 5 5H10C11.1046 5 12 5.89543 12 7V13C12 14.1046 11.1046 15 10 15H5C3.89543 15 3 14.1046 3 13V7Z"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="OCR">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VectorIcon" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="VectorIcon" Property="Data" Value="M4.5 3C3.67 3 3 3.67 3 4.5v2a.5.5 0 0 1-1 0v-2A2.5 2.5 0 0 1 4.5 2h2a.5.5 0 0 1 0 1h-2Zm0 14A1.5 1.5 0 0 1 3 15.5v-2a.5.5 0 0 0-1 0v2A2.5 2.5 0 0 0 4.5 18h2a.5.5 0 0 0 0-1h-2ZM17 4.5c0-.83-.67-1.5-1.5-1.5h-2a.5.5 0 0 1 0-1h2A2.5 2.5 0 0 1 18 4.5v2a.5.5 0 0 1-1 0v-2ZM15.5 17c.83 0 1.5-.67 1.5-1.5v-2a.5.5 0 0 1 1 0v2a2.5 2.5 0 0 1-2.5 2.5h-2a.5.5 0 0 1 0-1h2Zm-9-11a.5.5 0 0 0 0 1h7a.5.5 0 0 0 0-1h-7Zm0 3a.5.5 0 0 0 0 1h7a.5.5 0 0 0 0-1h-7ZM6 12.5c0-.28.22-.5.5-.5h4a.5.5 0 0 1 0 1h-4a.5.5 0 0 1-.5-.5Z"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Gallery">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="VectorIcon" Property="Visibility" Value="Visible"/>
