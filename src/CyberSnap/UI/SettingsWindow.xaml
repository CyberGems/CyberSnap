                                          VerticalAlignment="Center"
                                          AutomationProperties.Name="User Interface Scale"
                                          ToolTip="Increase the default size of windows, capture interface, widget and notifications."
                                          SelectionChanged="UiScaleCombo_SelectionChanged">
                                    <!-- Display % is renumbered: old 100→90 … old 140→130.
                                         Tag stays the real LayoutTransform factor (1.0–1.4).
                                         Default install uses Tag 1.1, shown as 100%. -->
                                    <ComboBoxItem Content="90%" Tag="1.0"
                                                  ToolTip="Slightly compact CyberSnap UI scale."
                                                  AutomationProperties.Name="90 percent UI scale"
                                                  AutomationProperties.HelpText="Use a slightly more compact CyberSnap window, notification, and capture-control size."/>
                                    <ComboBoxItem Content="100%" Tag="1.1"
                                                  ToolTip="Use the default CyberSnap UI scale."
                                                  AutomationProperties.Name="100 percent UI scale"
                                                  AutomationProperties.HelpText="Use the default CyberSnap window, notification, and capture-control size."/>
                                    <ComboBoxItem Content="110%" Tag="1.2"
                                                  ToolTip="Scale CyberSnap UI to 110%."
                                                  AutomationProperties.Name="110 percent UI scale"
                                                  AutomationProperties.HelpText="Make CyberSnap windows, notifications, and capture controls slightly larger."/>
                                    <ComboBoxItem Content="120%" Tag="1.3"
                                                  ToolTip="Scale CyberSnap UI to 120%."
                                                  AutomationProperties.Name="120 percent UI scale"
                                                  AutomationProperties.HelpText="Make CyberSnap windows, notifications, and capture controls larger."/>
                                    <ComboBoxItem Content="130%" Tag="1.4"
                                                  ToolTip="Scale CyberSnap UI to 130%."
                                                  AutomationProperties.Name="130 percent UI scale"
                                                  AutomationProperties.HelpText="Make CyberSnap windows, notifications, and capture controls much larger."/>
                                </ComboBox>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Show Instruction Banners -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE8D4;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Show instruction banners" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Show instruction banners for ruler, color picker, OCR, and recording." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="ShowToolBannersCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Show instruction banners"
                                          ToolTip="Show instruction banners for ruler, color picker, OCR, and recording."
                                          Checked="ShowToolBannersCheck_Changed" Unchecked="ShowToolBannersCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Disable Animated Effects -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE768;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Enable animated effects" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Enables animated transitions and visual effects across CyberSnap" Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="DisableAnimationsCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Enable animated effects"
                                          ToolTip="Enables animated transitions and visual effects across CyberSnap"
                                          Checked="DisableAnimationsCheck_Changed" Unchecked="DisableAnimationsCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Confirm Before Exit -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Services:LocalizationService.SourceText="Confirm before exit" Text="Confirm before exit" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Services:LocalizationService.SourceText="Show a confirmation menu on right-click before canceling capture, recording, or OCR." Text="Show a confirmation menu on right-click before canceling capture, recording, or OCR." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="ConfirmBeforeExitCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Confirm before exit"
                                          ToolTip="Show a confirmation menu on right-click before canceling capture, recording, or OCR."
                                          Checked="ConfirmBeforeExitCheck_Changed" Unchecked="ConfirmBeforeExitCheck_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="GeneralPreferenceStatusText"
                               Style="{StaticResource SettingsStatusText}"
                               Visibility="Collapsed"
                               Margin="4,8,0,0"/>

                    <TextBlock Services:LocalizationService.SourceText="Behavior after captures"
                               Text="Behavior after captures" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Style="{StaticResource SettingRow}" Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}" VerticalAlignment="Top" Margin="0,2,10,0">
                                    <TextBlock Text="&#xE930;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="After capture" Style="{StaticResource SettingTitle}"
                                               Services:LocalizationService.SourceText="After capture"/>
                                    <TextBlock Text="Choose what happens when a capture finishes. Add steps with + and remove them with ×."
                                               Style="{StaticResource SettingDescription}"
                                               Services:LocalizationService.SourceText="Choose what happens when a capture finishes. Add steps with + and remove them with ×."
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                            <controls:AfterCaptureOutcomeEditor x:Name="AfterCaptureOutcomeEditor"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Services:LocalizationService.SourceText="Standalone tools" Text="Standalone tools" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Ruler: Capture all screens -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE7F3;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Services:LocalizationService.SourceText="Ruler: Capture all screens" Text="Ruler: Capture all screens" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Services:LocalizationService.SourceText="When ON, Enter captures every monitor. When OFF, only the current screen." Text="When ON, Enter captures every monitor. When OFF, only the current screen." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="RulerCaptureAllScreensCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Ruler: Capture all screens"
                                          Services:LocalizationService.SourceToolTip="When enabled, the ruler's Enter capture takes every monitor. Applies only to multi-monitor setups."
                                          ToolTip="When enabled, the ruler's Enter capture takes every monitor. Applies only to multi-monitor setups."
                                          Checked="RulerCaptureAllScreensCheck_Changed" Unchecked="RulerCaptureAllScreensCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Ruler: Enable context menu -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE700;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Services:LocalizationService.SourceText="Ruler: Enable context menu" Text="Ruler: Enable context menu" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Services:LocalizationService.SourceText="When disabled, right-click exits the ruler instead of showing the context menu." Text="When disabled, right-click exits the ruler instead of showing the context menu." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="RulerContextMenuEnabledCheck" Grid.Column="2" Content="" FontSize="13" VerticalAlignment="Center"
                                          AutomationProperties.Name="Ruler: Enable context menu"
                                          Services:LocalizationService.SourceToolTip="When disabled, right-click exits the ruler instead of showing the context menu."
                                          ToolTip="When disabled, right-click exits the ruler instead of showing the context menu."
                                          Checked="RulerContextMenuEnabledCheck_Changed" Unchecked="RulerContextMenuEnabledCheck_Changed"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="System" Style="{StaticResource SectionLabel}"/>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <!-- Launch on startup -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE7E8;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Launch on startup" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Start CyberSnap automatically when Windows starts." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <CheckBox x:Name="StartWithWindowsCheck" Grid.Column="2" Content="" FontSize="13"
                                          AutomationProperties.Name="Launch on startup"
                                          ToolTip="Start CyberSnap automatically when Windows starts."
                                          VerticalAlignment="Center"
                                          Checked="StartWithWindowsCheck_Changed" Unchecked="StartWithWindowsCheck_Changed"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Export settings -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE74E;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Export settings" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Save your settings and achievements to a JSON file. API keys are redacted." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <Button x:Name="ExportSettingsBtn" Grid.Column="2" Content="Export" MinWidth="90"
                                        VerticalAlignment="Center" Cursor="Hand"
                                        ToolTip="Exports all settings and achievements (streaks, capture counts, medals) to a JSON file. API keys are removed for security."
                                        AutomationProperties.Name="Export settings"
                                        Click="ExportSettingsButton_Click"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Import settings -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE8E5;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Import settings" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Restore your settings and achievements from a previously exported JSON file." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <Button x:Name="ImportSettingsBtn" Grid.Column="2" Content="Import" MinWidth="90"
                                        VerticalAlignment="Center" Cursor="Hand"
                                        ToolTip="Restores all settings and achievements from an exported JSON file. Current settings will be replaced."
                                        AutomationProperties.Name="Import settings"
                                        Click="ImportSettingsButton_Click"/>
                            </Grid>
                            <Border Height="1" Background="{DynamicResource ThemeSeparatorBrush}" Margin="0,9,0,9"/>
                            <!-- Reset Settings -->
                            <Grid Style="{StaticResource SettingRow}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource SettingIconFrame}">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource SettingIconGlyph}"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Reset Settings" Style="{StaticResource SettingTitle}"/>
                                    <TextBlock Text="Restore every setting to its original defaults." Style="{StaticResource SettingDescription}"/>
                                </StackPanel>
                                <Button x:Name="ResetSettingsBtn" Grid.Column="2" Content="Reset" Style="{StaticResource DangerButton}"
                                        VerticalAlignment="Center" Cursor="Hand"
                                        ToolTip="Reset all settings to defaults"
                                        AutomationProperties.Name="Reset settings"
                                        Click="ResetSettingsButton_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="SettingsImportExportStatusText" Style="{StaticResource SettingsHelperText}"
                               Visibility="Collapsed"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.Name="Settings import and export status"
                               AutomationProperties.LiveSetting="Polite"
                               Margin="0,4,0,10"/>
                    <TextBlock x:Name="StartupPreferenceStatusText" Style="{StaticResource SettingsStatusText}"
                               Visibility="Collapsed"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                               AutomationProperties.Name="Startup preference status"
                               AutomationProperties.LiveSetting="Polite"
                               Margin="4,4,0,8"/>

                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="SoundsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="18,56,18,18">
                <StackPanel>
                    <TextBlock Text="Sounds" Style="{StaticResource SectionLabel}"/>
