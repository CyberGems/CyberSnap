<Window x:Class="CyberSnap.UI.CapturePreviewDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CyberSnap.UI.Controls"
        Title="Capture Preview"
        Height="480" Width="680"
        MinHeight="380" MinWidth="650"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="False"
        Icon="pack://application:,,,/Assets/Icons/CyberSnap.ico"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#FFF0F0F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#FF9A9A9A"/>
        <SolidColorBrush x:Key="ThemeMutedBrush" Color="#FF686868"/>
        <SolidColorBrush x:Key="ThemeCardBrush" Color="#FF2D2D2D"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#FF1E1E1E"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeWindowBorderBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="ThemeSeparatorBrush" Color="#0CFFFFFF"/>

        <Style x:Key="PreviewActionButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#15FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                    <Setter Property="BorderBrush" Value="#30FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewCancelButton" TargetType="Button" BasedOn="{StaticResource ChromeButtonBase}">
            <Setter Property="Background" Value="#0FEE4444"/>
            <Setter Property="BorderBrush" Value="#25EE4444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#FFEE6666"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#20EE4444"/>
                    <Setter Property="BorderBrush" Value="#50EE4444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="RootBorder" CornerRadius="12" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="0,0,0,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <controls:CyberSnapTitleBar x:Name="TitleBar" Grid.Row="0"
                                      Title="Capture Preview"
                                      ShowPinButton="True"
                                      CloseRequested="TitleBar_CloseRequested"
                                      PinRequested="TitleBar_PinRequested"/>

            <!-- Image Preview Box -->
            <Border Grid.Row="1" Margin="14,2,14,8" CornerRadius="8" Padding="6"
                    Background="{DynamicResource ThemeInputBackgroundBrush}"
                    BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1">
                <Grid ClipToBounds="True">
                    <Image x:Name="PreviewImage" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Grid>
            </Border>

            <!-- After capture active options bar (bottom bar above action buttons) -->
            <Border Grid.Row="2" Margin="14,0,14,0" Padding="10,6" CornerRadius="8"
                    Background="{DynamicResource ThemeCardBrush}"
                    BorderBrush="{DynamicResource ThemeInputBorderBrush}" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0" LastChildFill="True" VerticalAlignment="Center">
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                            <Image x:Name="AfterCaptureHeaderIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="AfterCaptureHeaderLabel" Text="Automatic actions:" FontSize="11.5" FontWeight="SemiBold"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel x:Name="AfterCapturePillsPanel" Orientation="Horizontal" VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Edit options button (opens Settings on Captura tab) -->
                    <Button x:Name="EditAfterCaptureSettingsBtn" Grid.Column="1" Click="EditAfterCaptureSettingsBtn_Click"
                            Style="{StaticResource PreviewActionButton}" Height="26" Padding="8,0" Margin="8,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image x:Name="EditSettingsBtnIcon" Width="12" Height="12" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="EditSettingsBtnText" Text="Edit" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- Optional actions bar -->
            <StackPanel Grid.Row="3" Margin="14,12,14,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock x:Name="OptionalActionsHeaderLabel" Text="Optional actions" FontSize="11.5" FontWeight="SemiBold"
                               Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"
                               ToolTip="Buttons covered by an active automatic action are disabled."
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Dest buttons -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="SaveBtn" Click="SaveBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="SaveIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SaveText" Text="Save" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="CopyBtn" Click="CopyBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="CopyIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="CopyText" Text="Copy" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="EditBtn" Click="EditBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="EditIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="EditText" Text="Edit" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ShareBtn" Click="ShareBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="ShareIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ShareText" Text="Share" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="GalleryBtn" Click="GalleryBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Image x:Name="GalleryIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="GalleryText" Text="Gallery" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Close button (neutral style, replaces old red Cancel button) -->
                    <Button Grid.Column="1" x:Name="CancelBtn" Click="CancelBtn_Click" Style="{StaticResource PreviewActionButton}" MinWidth="95" Height="32">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Image x:Name="CancelIcon" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="CancelText" Text="Close" VerticalAlignment="Center" FontSize="11.5" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <TextBlock Grid.Row="4" x:Name="ViewerHintBadge"
                       Text="The system viewer opens when this window closes."
                       Visibility="Collapsed" Margin="14,8,14,0" FontSize="11"
                       TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                       ToolTip="The system viewer opens when this window closes."/>
        </Grid>
    </Border>
</Window>
